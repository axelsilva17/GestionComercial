# EditorConfig for GestionComercial
root = true

# Default: severity from project (nullable enabled)
[*.cs]

# ── Auto-generated EF Core migrations ──────────────────────────────────────
[**/Migrations/*.cs]
dotnet_diagnostic.CS8618.severity = none    # Non-nullable field not initialized (navigation properties)
dotnet_diagnostic.CS8601.severity = none    # Possible null reference assignment
dotnet_diagnostic.CS8602.severity = none    # Dereference of possibly null reference
dotnet_diagnostic.CS8603.severity = none    # Possible null reference return
dotnet_diagnostic.CS8625.severity = none    # Cannot convert null literal

# ── All code: avoid common noise ──────────────────────────────────────────
[*.cs]
dotnet_diagnostic.CS0105.severity = silent   # Duplicate using (harmless)
dotnet_diagnostic.CS0219.severity = silent   # Variable assigned but not used

# ── Nullable RT warnings: bajo riesgo en desktop (WPF garantiza init, ViewModels
#    tienen guards, servicios manejan nulos en runtime, son 135 instancias de ruido) ──
[*.cs]
dotnet_diagnostic.CS8602.severity = silent   # Dereference of possibly null ref
dotnet_diagnostic.CS8625.severity = silent   # Cannot convert null to non-nullable ref
dotnet_diagnostic.CS8603.severity = silent   # Possible null reference return
dotnet_diagnostic.CS8601.severity = silent   # Possible null reference assignment
dotnet_diagnostic.CS8604.severity = silent   # Possible null reference argument
dotnet_diagnostic.CS8629.severity = silent   # Nullable value type may be null
