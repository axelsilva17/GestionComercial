<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Familias de Fuentes -->
    <FontFamily x:Key="FuentePrincipal">Segoe UI</FontFamily>
    <FontFamily x:Key="FuenteSecundaria">Segoe UI</FontFamily>
    <FontFamily x:Key="FuenteMonospace">Consolas</FontFamily>

    <!-- Tamanios de Fuente -->
    <system:Double x:Key="TamanioFuenteXS" xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
    <system:Double x:Key="TamanioFuenteS" xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
    <system:Double x:Key="TamanioFuenteM" xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
    <system:Double x:Key="TamanioFuenteL" xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
    <system:Double x:Key="TamanioFuenteXL" xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
    <system:Double x:Key="TamanioFuenteXXL" xmlns:system="clr-namespace:System;assembly=mscorlib">24</system:Double>
    <system:Double x:Key="TamanioFuenteXXXL" xmlns:system="clr-namespace:System;assembly=mscorlib">32</system:Double>

    <!-- Pesos de Fuente -->
    <FontWeight x:Key="PesoFuenteLight">Light</FontWeight>
    <FontWeight x:Key="PesoFuenteNormal">Normal</FontWeight>
    <FontWeight x:Key="PesoFuenteMedium">Medium</FontWeight>
    <FontWeight x:Key="PesoFuenteSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="PesoFuenteBold">Bold</FontWeight>

</ResourceDictionary>