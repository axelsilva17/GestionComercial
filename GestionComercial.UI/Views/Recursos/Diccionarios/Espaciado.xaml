<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Espaciados -->
    <Thickness x:Key="EspaciadoXS">4</Thickness>
    <Thickness x:Key="EspaciadoS">8</Thickness>
    <Thickness x:Key="EspaciadoM">12</Thickness>
    <Thickness x:Key="EspaciadoL">16</Thickness>
    <Thickness x:Key="EspaciadoXL">24</Thickness>
    <Thickness x:Key="EspaciadoXXL">32</Thickness>

    <!-- Padding -->
    <Thickness x:Key="PaddingXS">4</Thickness>
    <Thickness x:Key="PaddingS">8</Thickness>
    <Thickness x:Key="PaddingM">12</Thickness>
    <Thickness x:Key="PaddingL">16</Thickness>
    <Thickness x:Key="PaddingXL">24</Thickness>
    <Thickness x:Key="PaddingXXL">32</Thickness>

    <!-- Padding Horizontal -->
    <Thickness x:Key="PaddingHorizontalS">8,0</Thickness>
    <Thickness x:Key="PaddingHorizontalM">12,0</Thickness>
    <Thickness x:Key="PaddingHorizontalL">16,0</Thickness>
    <Thickness x:Key="PaddingHorizontalXL">24,0</Thickness>

    <!-- Padding Vertical -->
    <Thickness x:Key="PaddingVerticalS">0,8</Thickness>
    <Thickness x:Key="PaddingVerticalM">0,12</Thickness>
    <Thickness x:Key="PaddingVerticalL">0,16</Thickness>
    <Thickness x:Key="PaddingVerticalXL">0,24</Thickness>

    <!-- Bordes Redondeados -->
    <CornerRadius x:Key="RadiusS">4</CornerRadius>
    <CornerRadius x:Key="RadiusM">6</CornerRadius>
    <CornerRadius x:Key="RadiusL">8</CornerRadius>
    <CornerRadius x:Key="RadiusXL">12</CornerRadius>
    <CornerRadius x:Key="RadiusXXL">16</CornerRadius>
    <CornerRadius x:Key="RadiusFull">999</CornerRadius>

</ResourceDictionary>