<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fondos -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0F172A"/>
    <!-- Fondo principal oscuro -->
    <SolidColorBrush x:Key="CardBrush" Color="#1E293B"/>
    <!-- Tarjetas / sidebar -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#243447"/>
    <!-- Superficie secundaria -->

    <!-- Texto -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#7DD3FC"/>
    <!-- Texto principal claro -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7DD3FC"/>
    <!-- Texto secundario -->
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#38BDF8"/>
    <!-- Texto terciario / secciones -->

    <!-- Bordes y hover -->
    <SolidColorBrush x:Key="BorderBrush" Color="#2A3D52"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#2A3D52"/>

    <!-- Acciones / colores principales -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#38BDF8"/>
    <!-- Color primario botones activos -->
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <!-- Color error / cerrar -->

    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="LightBackgroundBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#0F1419"/>
</ResourceDictionary>
