<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Storyboard x:Key="ShakeAnimation">
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
            Duration="0:0:0.4">

            <EasingDoubleKeyFrame Value="-10" KeyTime="0:0:0.05"/>
            <EasingDoubleKeyFrame Value="10" KeyTime="0:0:0.1"/>
            <EasingDoubleKeyFrame Value="-8" KeyTime="0:0:0.15"/>
            <EasingDoubleKeyFrame Value="8" KeyTime="0:0:0.2"/>
            <EasingDoubleKeyFrame Value="0" KeyTime="0:0:0.3"/>

        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

</ResourceDictionary>
