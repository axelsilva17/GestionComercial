<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         ESTILOS GLOBALES PARA FILTROS
         Consistencia visual en todas las vistas de la app
    ═══════════════════════════════════════════════════════ -->

    <!-- ── Filter ComboBox ─────────────────────────────────── -->
    <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height"              Value="44"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="Background"          Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground"          Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"         Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Padding"             Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="border"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <ContentPresenter x:Name="ContentSite"
                                                  Margin="12,0,30,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                <TextBlock x:Name="Arrow"
                                           Text="▼"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="Arrow" Property="Text" Value="▲"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Filter DatePicker ───────────────────────────────── -->
    <Style x:Key="FilterDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Height"              Value="44"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="Background"         Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground"         Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"        Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness"    Value="1"/>
        <Setter Property="Padding"            Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ── Filter TextBox ──────────────────────────────────── -->
    <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height"              Value="44"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="Foreground"          Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush"          Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background"         Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="SelectionBrush"      Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderBrush"         Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Padding"            Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>