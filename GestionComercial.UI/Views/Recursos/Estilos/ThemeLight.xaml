<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========== BASE COLORS - Light ========== -->
    <Color x:Key="BackgroundColor">#F5F7FA</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#E8EEF5</Color>
    <Color x:Key="TextPrimaryColor">#1E293B</Color>
    <Color x:Key="TextSecondaryColor">#475569</Color>
    <Color x:Key="TextTertiaryColor">#0EA5E9</Color>
    <Color x:Key="BorderColor">#CBD5E1</Color>
    <Color x:Key="InputBackgroundColor">#F1F5F9</Color>
    <Color x:Key="HoverColor">#E2E8F0</Color>
    <Color x:Key="DisabledColor">#94A3B8</Color>

    <!-- ========== ACCENT COLORS - coherente con Dark ========== -->
    <Color x:Key="PrimaryColor">#0284C7</Color>
    <Color x:Key="PrimaryHoverColor">#0369A1</Color>
    <Color x:Key="PrimaryActiveColor">#075985</Color>
    <Color x:Key="AccentColor">#38BDF8</Color>
    <Color x:Key="ErrorColor">#DC2626</Color>
    <Color x:Key="SuccessColor">#059669</Color>
    <Color x:Key="WarningColor">#D97706</Color>

    <!-- ========== BRUSHES ========== -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="PrimaryActiveBrush" Color="{StaticResource PrimaryActiveColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <!-- ========== EFFECTS ========== -->
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="40"
                      ShadowDepth="0"
                      Opacity="0.15"
                      Color="#000000"/>

    <DropShadowEffect x:Key="SubtleShadow"
                      BlurRadius="20"
                      ShadowDepth="0"
                      Opacity="0.08"
                      Color="#000000"/>

</ResourceDictionary>
