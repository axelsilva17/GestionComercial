<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Filter TextBox - consistent 44px height with filter controls -->
    <Style x:Key="FilterTextBox" TargetType="TextBox">
        <Setter Property="Height"              Value="44"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="Foreground"          Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush"          Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background"         Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="SelectionBrush"      Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderBrush"         Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Padding"            Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default TextBox style -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>
    <Style x:Key="FloatingTextBoxStyle" TargetType="TextBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>

                        <Border BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"/>

                        <TextBlock x:Name="FloatingLabel"
                                   Text="{TemplateBinding Tag}"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   IsHitTestVisible="False"/>

                        <ScrollViewer Margin="12,18,12,4"
                                      x:Name="PART_ContentHost"/>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="FloatingLabel"
                                    Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="-16"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="FloatingLabel"
                                    Property="FontSize"
                                    Value="11"/>
                            <Setter TargetName="FloatingLabel"
                                    Property="Foreground"
                                    Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>

                        <Trigger Property="Text" Value="">
                            <Setter TargetName="FloatingLabel"
                                    Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="0"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
    </Style>
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

</ResourceDictionary>
