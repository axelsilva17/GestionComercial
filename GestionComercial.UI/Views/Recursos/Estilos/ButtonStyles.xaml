<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Recursos locales -->
    <SolidColorBrush x:Key="ColorSecundario" Color="#64748B"/>
    <SolidColorBrush x:Key="ColorSuperficie" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ColorPrimario" Color="#2563EB"/>
    <SolidColorBrush x:Key="ColorBorde" Color="#E2E8F0"/>
    <Thickness x:Key="MarginControl">0,0,0,10</Thickness>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                        CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="BotonSecundarioSimple" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ColorSuperficie}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorPrimario}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorBorde}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="15,8"/>
    </Style>

</ResourceDictionary>