<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#0F172A"/>
      <stop offset="50%"  stop-color="#1E293B"/>
      <stop offset="100%" stop-color="#243447"/>
    </linearGradient>
    <linearGradient id="b1" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.22"/>
    </linearGradient>
    <linearGradient id="b2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.75"/>
      <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.38"/>
    </linearGradient>
    <linearGradient id="b3" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#60A5FA"/>
      <stop offset="100%" stop-color="#2563EB"/>
    </linearGradient>
    <linearGradient id="b4" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.88"/>
      <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.45"/>
    </linearGradient>
    <linearGradient id="b5" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.60"/>
      <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.25"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>
  </defs>

  <!-- Fondo con esquinas redondeadas -->
  <rect width="200" height="200" rx="30" fill="url(#bg)"/>

  <!-- Decoración: círculo difuso arriba-izquierda -->
  <circle cx="20" cy="20" r="80" fill="#60A5FA" opacity="0.04"/>
  <!-- Decoración: círculo difuso abajo-derecha -->
  <circle cx="185" cy="185" r="90" fill="#3B82F6" opacity="0.05"/>

  <!-- ── BLOQUES (baseline Y=158, centrados en 200x200) ── -->

  <!-- COL 1 · estrecho, bajo -->
  <rect x="30"  y="130" width="20" height="28" rx="2" fill="url(#b1)"/>

  <!-- COL 2 · medio -->
  <rect x="57"  y="108" width="24" height="50" rx="2" fill="url(#b2)"/>

  <!-- COL 3 · ACENTO azul — la más alta -->
  <rect x="89"  y="72"  width="28" height="86" rx="2" fill="url(#b3)" filter="url(#glow)"/>
  <!-- Brillo interno -->
  <rect x="91"  y="74"  width="11" height="5"  rx="1" fill="#FFFFFF" opacity="0.28"/>

  <!-- COL 4 · ancho, alto medio -->
  <rect x="125" y="90"  width="24" height="68" rx="2" fill="url(#b4)"/>

  <!-- COL 5 · estrecho, corto -->
  <rect x="157" y="118" width="18" height="40" rx="2" fill="url(#b5)"/>

  <!-- Línea base -->
  <line x1="26" y1="161" x2="178" y2="161" stroke="#FFFFFF" stroke-width="1" opacity="0.15"/>

</svg>
