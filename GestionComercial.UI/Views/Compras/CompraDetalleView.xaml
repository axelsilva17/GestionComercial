<UserControl x:Class="GestionComercial.UI.Views.Compras.CompraDetalleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>

        <Style x:Key="DetalleLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="DetalleValor" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ItemRow" TargetType="DataGridRow">
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="rb" Background="Transparent" CornerRadius="8" Margin="4,2">
                            <DataGridCellsPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rb" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ItemsGrid" TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="None"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="RowHeight"             Value="52"/>
            <Setter Property="ColumnHeaderHeight"    Value="36"/>
            <Setter Property="RowStyle"              Value="{StaticResource ItemRow}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="12,0" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="Volver" Grid.Column="0" Content="← Volver"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource PrimaryBrush}"
                    FontSize="14" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,20,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="10,8">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">
                    <Run Text="Compra "/>
                    <Run Text="#" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Run Text="{Binding IdCompra, Mode=OneWay}"
                         Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                </TextBlock>
                <TextBlock Text="{Binding Fecha, StringFormat='dd/MM/yyyy  HH:mm'}"
                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Info general -->
        <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="PROVEEDOR" Style="{StaticResource DetalleLabel}"/>
                    <TextBlock Text="{Binding ProveedorNombre}" Style="{StaticResource DetalleValor}"/>
                    <TextBlock Text="TELÉFONO" Style="{StaticResource DetalleLabel}"/>
                    <TextBlock Text="{Binding ProveedorTelefono}" Style="{StaticResource DetalleValor}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="SUCURSAL" Style="{StaticResource DetalleLabel}"/>
                    <TextBlock Text="{Binding SucursalNombre}" Style="{StaticResource DetalleValor}"/>
                    <TextBlock Text="REGISTRADO POR" Style="{StaticResource DetalleLabel}"/>
                    <TextBlock Text="{Binding UsuarioNombre}" Style="{StaticResource DetalleValor}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="PRODUCTOS" Style="{StaticResource DetalleLabel}"/>
                    <TextBlock Text="{Binding CantidadProductos}" Style="{StaticResource DetalleValor}"/>
                    <TextBlock Text="UNIDADES TOTALES" Style="{StaticResource DetalleLabel}"/>
                    <TextBlock Text="{Binding UnidadesTotales}" Style="{StaticResource DetalleValor}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                    <TextBlock Text="TOTAL" Style="{StaticResource DetalleLabel}"/>
                    <TextBlock Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,16"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabla de productos -->
        <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PRODUCTOS COMPRADOS"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="20,16,0,0"/>

                <DataGrid Grid.Row="1" Style="{StaticResource ItemsGrid}"
                          ItemsSource="{Binding Items}" Margin="4,4">
                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="PRODUCTO" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="{Binding ProductoNombre}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CodigoBarra}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="CATEGORÍA" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CategoriaNombre}"
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="CANTIDAD" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Cantidad}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="PRECIO COSTO" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PrecioCosto, Converter={StaticResource DecimalToMoneda}}"
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Margin="0,0,16,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="SUBTOTAL" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SubTotal, Converter={StaticResource DecimalToMoneda}}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Margin="0,0,20,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.RowSpan="2" Background="#CC0F172A" CornerRadius="12"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="180" Height="3"
                                     Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"
                                     Background="{DynamicResource SurfaceBrush}"/>
                        <TextBlock Text="Cargando..." Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer total -->
        <Border Grid.Row="6" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="OBSERVACIONES" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Observacion}"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="TOTAL COMPRA" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
