<UserControl x:Class="GestionComercial.UI.Views.Compras.CompraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibility"/>
        <converters:FechaToStringConverter x:Key="FechaToString"/>

        <!-- Estilos del DataGrid para coincidir con el sistema -->
        <Style x:Key="ItemRow" TargetType="DataGridRow">
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="rb" Background="Transparent" CornerRadius="8" Margin="4,2">
                            <DataGridCellsPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rb" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ItemsGrid" TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="None"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="RowHeight"             Value="52"/>
            <Setter Property="ColumnHeaderHeight"    Value="36"/>
            <Setter Property="RowStyle"              Value="{StaticResource ItemRow}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="12,0" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- COLUMNA PRINCIPAL -->
        <Grid Grid.Column="0" Margin="24,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: Volver + Título + Proveedor -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="Volver" Grid.Column="0" Content="← Volver"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource PrimaryBrush}"
                        FontSize="14" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="10,8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Nueva Compra" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding ProveedorNombre}" FontSize="13" 
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,3,0,0" FontWeight="Medium"/>
                </StackPanel>

                <!-- Selector de proveedor -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Height="44" Padding="14,0" MinWidth="220">
                    <ComboBox x:Name="ProveedorComboBox"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              FontSize="13" VerticalAlignment="Center"
                              ItemsSource="{Binding Proveedores}"
                              SelectedItem="{Binding ProveedorSeleccionado, Mode=TwoWay}"
                              DisplayMemberPath="Nombre"
                              Style="{StaticResource FilterComboBoxStyle}"/>
                </Border>
            </Grid>

            <!-- Buscador de productos con popup -->
            <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Input de búsqueda -->
                    <Border x:Name="BusquedaProductoBorder" Grid.Row="0" 
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Height="44">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center"
                                       Margin="12,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="BusquedaProducto" Grid.Column="1"
                                     Text="{Binding BusquedaProducto, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="14" VerticalContentAlignment="Center" Padding="0,0,12,0"
                                     KeyDown="BusquedaProducto_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Popup de resultados (como en Ventas) -->
                    <Popup Grid.Row="1"
                           IsOpen="{Binding MostrarPopupBusqueda}"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=BusquedaProductoBorder}"
                           StaysOpen="False"
                           AllowsTransparency="False"
                           PopupAnimation="Slide"
                           Panel.ZIndex="999"
                           Margin="0,4,0,0">
                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Width="{Binding ElementName=BusquedaProductoBorder, Path=ActualWidth}"
                                MaxHeight="240">
                            <ListBox ItemsSource="{Binding ProductosEncontrados}"
                                     SelectedItem="{Binding ProductoSeleccionado}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="ResultadosBusqueda_MouseDoubleClick">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="border" Background="Transparent"
                                                            Padding="{TemplateBinding Padding}"
                                                            CornerRadius="4" Margin="4,2">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nombre}" FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{Binding CodigoBarra}"/>
                                                <Run Text=" | Stock: "/>
                                                <Run Text="{Binding StockActual}"/>
                                                <Run Text=" | $"/>
                                                <Run Text="{Binding PrecioCostoActual}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>

                    <!-- Cantidad y Precio antes de agregar (cuando hay producto seleccionado) -->
                    <Grid Grid.Row="2" Margin="0,12,0,0"
                          Visibility="{Binding ProductoSeleccionado, Converter={StaticResource NullToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Campo Cantidad -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Height="44">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cant:" FontSize="12" VerticalAlignment="Center"
                                           Margin="12,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Grid.Column="1" 
                                         Text="{Binding CantidadAgregar, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="14" FontWeight="SemiBold"
                                         VerticalContentAlignment="Center" Padding="0,0,12,0"/>
                            </Grid>
                        </Border>

                        <!-- Campo Precio Costo -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Height="44">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="$" FontSize="12" VerticalAlignment="Center"
                                           Margin="12,0,4,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Grid.Column="1" 
                                         Text="{Binding PrecioAgregar, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="14" FontWeight="SemiBold"
                                         VerticalContentAlignment="Center" Padding="0,0,12,0"/>
                            </Grid>
                        </Border>

                        <!-- Botón Agregar -->
                        <Button x:Name="AgregarProducto" Grid.Column="4"
                                Height="44" Padding="20,0" FontSize="13"
                                Style="{StaticResource PrimaryButton}" MinWidth="120">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="15" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Agregar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Tabla de items del carrito -->
            <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PRODUCTOS EN EL CARRITO"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               Margin="16,12,16,8"/>

                    <DataGrid Grid.Row="1" 
                              Style="{StaticResource ItemsGrid}"
                              ItemsSource="{Binding Items}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="PRODUCTO" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding ProductoNombre}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CodigoBarra}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="CANTIDAD" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="−" Width="28" Height="28" FontSize="16"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand"
                                                    Command="{Binding DataContext.RestarCantidadCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="{Binding Cantidad}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="10,0"/>
                                            <Button Content="＋" Width="28" Height="28" FontSize="14"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand"
                                                    Command="{Binding DataContext.SumarCantidadCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="SUBTOTAL" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SubTotal, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="30" Height="30" FontSize="12"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                Cursor="Hand" HorizontalAlignment="Center"
                                                Command="{Binding DataContext.QuitarItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Mensaje si no hay items -->
                    <TextBlock Grid.Row="1" Text="No hay productos en el carrito"
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Items.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- PANEL LATERAL -->
        <Border Grid.Column="2" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid Margin="20,24,20,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Historial del proveedor -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="ÚLTIMAS COMPRAS" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    
                    <ItemsControl ItemsSource="{Binding HistorialProveedor}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Fecha, Converter={StaticResource FechaToString}}"
                                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <!-- Mostrar cantidad de items -->
                                            <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                                                <Run Text=" productos"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Mensaje si no hay historial -->
                    <TextBlock Text="No hay compras anteriores"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding HistorialProveedor.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Inverse}"
                               Margin="0,0,0,12"/>
                </StackPanel>

                <Separator Grid.Row="1" Background="{DynamicResource BorderBrush}" Margin="0,16,0,16"/>

                <!-- Resumen -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductoNombre}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                            <Run Text="{Binding Cantidad}"/>
                                            <Run Text=" x "/>
                                            <Run Text="{Binding PrecioCosto, Converter={StaticResource DecimalToMoneda}}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SubTotal, Converter={StaticResource DecimalToMoneda}}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Total y botón -->
                <StackPanel Grid.Row="3">
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="TOTAL" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="OBSERVACIONES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <TextBox x:Name="Observacion"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13" TextWrapping="Wrap" AcceptsReturn="True"
                                     Height="60" VerticalContentAlignment="Top"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="ConfirmarCompra"
                            Height="52" FontSize="15" FontWeight="SemiBold"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding CanGuardar}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Confirmar Compra" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>