<UserControl x:Class="GestionComercial.UI.Views.Compras.CompraListadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:NullVisibilityConverter   x:Key="NullToVisibility"/>

        <Style x:Key="CompraRow" TargetType="DataGridRow">
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="rb" Background="Transparent" CornerRadius="8" Margin="4,2">
                            <DataGridCellsPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rb" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="rb" Property="Background" Value="#1A3A5C"/>
                                <Setter TargetName="rb" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="rb" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComprasGrid" TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="None"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="SelectionUnit"         Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="RowHeight"             Value="56"/>
            <Setter Property="ColumnHeaderHeight"    Value="38"/>
            <Setter Property="RowStyle"              Value="{StaticResource CompraRow}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="12,0" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SideValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL PRINCIPAL -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Compras" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Historial de órdenes de compra"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button x:Name="NuevaCompra" Grid.Column="1"
                        Height="44" Padding="22,0" FontSize="13"
                        Style="{StaticResource PrimaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Nueva Compra" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Métricas -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="ESTE MES" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalComprasMes, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,6,0,0"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                            <Run Text="{Binding CantidadComprasMes}"/>
                            <Run Text=" órdenes"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="PROMEDIO POR ORDEN" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PromedioCompra, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="PROVEEDOR MÁS FRECUENTE" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ProveedorTop}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="PRODUCTOS REPUESTOS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ProductosRepuestos}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="este mes" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filtros -->
            <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="155"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="155"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Height="38">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center"
                                       Margin="10,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="TextoBusqueda" Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13" VerticalContentAlignment="Center" Padding="0,0,10,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Height="38" Padding="10,0">
                        <DatePicker x:Name="FechaDesde" Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="4" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Height="38" Padding="10,0">
                        <DatePicker x:Name="FechaHasta" Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                    </Border>

                    <ComboBox x:Name="ProveedorFiltro" Grid.Column="6" Height="38" FontSize="13"
                              ItemsSource="{Binding Proveedores}"
                              DisplayMemberPath="Nombre"
                              Background="{DynamicResource SurfaceBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                    <Button x:Name="Buscar" Grid.Column="8"
                            Content="Buscar" Height="38" Padding="18,0"
                            FontSize="13" Style="{StaticResource PrimaryButton}"/>
                </Grid>
            </Border>

            <!-- Tabla -->
            <Border Grid.Row="6" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" ClipToBounds="True">
                <Grid>
                    <DataGrid x:Name="CompraSeleccionada" Style="{StaticResource ComprasGrid}"
                              ItemsSource="{Binding Compras}" Margin="4,4">
                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="N° ORDEN" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="12,0" VerticalAlignment="Center">
                                            <Run Text="#" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                            <Run Text="{Binding IdCompra}" Foreground="{DynamicResource PrimaryBrush}"
                                                 FontWeight="SemiBold" FontSize="14" FontFamily="Consolas"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="FECHA" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding Fecha, StringFormat='dd/MM/yyyy'}"
                                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Fecha, StringFormat='HH:mm'}"
                                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="PROVEEDOR" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="{DynamicResource SurfaceBrush}">
                                                <TextBlock Text="{Binding ProveedorInicial}" FontSize="13" FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock Text="{Binding ProveedorNombre}" FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding UsuarioNombre}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="PRODUCTOS" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Run Text="{Binding CantidadProductos}"/>
                                            <Run Text=" ítem(s)"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="TOTAL" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   Margin="0,0,20,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="›" FontSize="20"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#CC0F172A" CornerRadius="12"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="180" Height="3"
                                         Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"
                                         Background="{DynamicResource SurfaceBrush}"/>
                            <TextBlock Text="Cargando compras..." Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Paginación -->
            <Grid Grid.Row="7" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                    <Run Text="Mostrando "/>
                    <Run Text="{Binding ComprasMostradas, Mode=OneWay}" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Run Text=" de "/>
                    <Run Text="{Binding TotalCompras, Mode=OneWay}" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="PaginaAnterior" Content="← Ant"
                            Height="34" Padding="14,0" FontSize="12"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"/>
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14,0" Height="34">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12">
                            <Run Text="{Binding PaginaActual, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text=" / " Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Run Text="{Binding TotalPaginas, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                    <Button x:Name="PaginaSiguiente" Content="Sig →"
                            Height="34" Padding="14,0" FontSize="12"
                            Style="{StaticResource PrimaryButton}" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- SIDEBAR DETALLE COMPRA -->
        <Border Grid.Column="1" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding CompraSeleccionada, Converter={StaticResource NullToVisibility}}">
            <Grid Width="300">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="22,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="DETALLE DE COMPRA" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0">
                                    <Run Text="#" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <Run Text="{Binding CompraSeleccionada.IdCompra, Mode=OneWay}"
                                         Foreground="{DynamicResource PrimaryBrush}" FontFamily="Consolas"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="CerrarDetalle" Content="✕"
                                    Width="28" Height="28" FontSize="13"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Cursor="Hand" VerticalAlignment="Top"/>
                        </Grid>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="PROVEEDOR" Style="{StaticResource SideLabel}"/>
                        <TextBlock Text="{Binding CompraSeleccionada.ProveedorNombre, Mode=OneWay}"
                                   Style="{StaticResource SideValue}"/>

                        <TextBlock Text="FECHA" Style="{StaticResource SideLabel}"/>
                        <TextBlock Text="{Binding CompraSeleccionada.Fecha, StringFormat='dd/MM/yyyy   HH:mm', Mode=OneWay}"
                                   Style="{StaticResource SideValue}"/>

                        <TextBlock Text="REGISTRADO POR" Style="{StaticResource SideLabel}"/>
                        <TextBlock Text="{Binding CompraSeleccionada.UsuarioNombre, Mode=OneWay}"
                                   Style="{StaticResource SideValue}"/>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                        <!-- Items de la compra -->
                        <TextBlock Text="PRODUCTOS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding CompraSeleccionada.Items, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductoNombre}" FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding Cantidad}"/>
                                                <Run Text=" x "/>
                                                <Run Text="{Binding PrecioCosto, Converter={StaticResource DecimalToMoneda}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SubTotal, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,8,0,12"/>

                        <Grid>
                            <TextBlock Text="TOTAL" FontWeight="Bold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding CompraSeleccionada.Total, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                       FontWeight="Bold" FontSize="20"
                                       Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
