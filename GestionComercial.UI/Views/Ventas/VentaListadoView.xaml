<UserControl x:Class="GestionComercial.UI.Views.Ventas.VentaListadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="VentaListadoView_PreviewKeyDown">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacity"/>

        <Style x:Key="FiltroButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Badge de estado -->
        <Style x:Key="BadgePendiente" TargetType="Border">
            <Setter Property="Background"     Value="#1AF59E0B"/>
            <Setter Property="BorderBrush"    Value="#F59E0B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="6"/>
            <Setter Property="Padding"        Value="8,3"/>
        </Style>
        <Style x:Key="BadgePagada" TargetType="Border">
            <Setter Property="Background"     Value="#1A10B981"/>
            <Setter Property="BorderBrush"    Value="#10B981"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="6"/>
            <Setter Property="Padding"        Value="8,3"/>
        </Style>
        <Style x:Key="BadgeAnulada" TargetType="Border">
            <Setter Property="Background"     Value="#1AEF4444"/>
            <Setter Property="BorderBrush"    Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="6"/>
            <Setter Property="Padding"        Value="8,3"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Historial de Ventas"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Total (pagadas): " FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalFiltrado, Converter={StaticResource DecimalToMoneda}}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource SuccessBrush}"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="4,2" Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="Ctrl+N" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Border>
                <Button x:Name="NuevaVenta"
                        Height="44" Padding="20,0" FontSize="13"
                        Style="{StaticResource PrimaryButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="＋" FontSize="15" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Nueva Venta" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            </StackPanel>
        </Grid>

        <!-- Filtros rápidos de fecha -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="FiltrarHoy"        Content="hoy"         Height="32" Padding="14,0" FontSize="12" Margin="0,0,8,0"  Style="{StaticResource FiltroButton}" ToolTip="Ctrl+H - Hoy"/>
            <Button x:Name="FiltrarEstaSemana" Content="Esta semana" Height="32" Padding="14,0" FontSize="12" Margin="0,0,8,0"  Style="{StaticResource FiltroButton}" ToolTip="Ctrl+S - Esta semana"/>
            <Button x:Name="FiltrarEsteMes"    Content="Este mes"    Height="32" Padding="14,0" FontSize="12" Margin="0,0,24,0" Style="{StaticResource FiltroButton}" ToolTip="Ctrl+M - Este mes"/>

            <TextBlock Text="Desde:" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <DatePicker SelectedDate="{Binding FechaDesde}" Height="36"
                        Background="{DynamicResource SurfaceBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,0"/>
            <TextBlock Text="Hasta:" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <DatePicker SelectedDate="{Binding FechaHasta}" Height="36"
                        Background="{DynamicResource SurfaceBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,0"/>
            <Button x:Name="Buscar" Content="🔍 Buscar" Height="36" Padding="16,0" FontSize="13"
                    Style="{StaticResource PrimaryButton}" ToolTip="Enter - Buscar"/>
        </StackPanel>

        <!-- Filtro por estado -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <TextBlock Text="Filtrar por estado:" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox ItemsSource="{Binding EstadosFiltro}"
                      SelectedItem="{Binding FiltroEstado}"
                      Width="140" Height="36"
                      Background="{DynamicResource SurfaceBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Tabla historial -->
        <Border Grid.Row="6" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="12" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Ventas}"
                      SelectedItem="{Binding VentaSeleccionada}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="None"
                      Background="Transparent" BorderThickness="0"
                      HeadersVisibility="Column"
                      FontSize="13" RowHeight="52" ColumnHeaderHeight="36"
                      SelectionMode="Single" SelectionUnit="FullRow">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="FontSize"        Value="10"/>
                        <Setter Property="FontWeight"      Value="Bold"/>
                        <Setter Property="Padding"         Value="16,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="16,0" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="#" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IdVenta, StringFormat='#{0:D5}'}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="FECHA" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Fecha, StringFormat='dd/MM/yyyy HH:mm'}"
                                           FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="CLIENTE" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ClienteNombre}"
                                           FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="VENDEDOR" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UsuarioNombre}"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="TOTAL" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalFinal, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Badge de estado con color dinámico -->
                    <DataGridTemplateColumn Header="ESTADO" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource BadgePagada}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                    <Setter Property="Background"     Value="#1AF59E0B"/>
                                                    <Setter Property="BorderBrush"    Value="#F59E0B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Estado}" Value="Anulada">
                                                    <Setter Property="Background"     Value="#1AEF4444"/>
                                                    <Setter Property="BorderBrush"    Value="#EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Estado}" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#10B981"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Estado}" Value="Anulada">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Botones de acción sobre la venta seleccionada -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="VerDetalle"
                    Height="40" Padding="18,0" FontSize="13" Margin="0,0,10,0"
                    IsEnabled="{Binding PuedeVerDetalle}"
                    ToolTip="Enter - Ver detalle">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor"          Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8" Opacity="{TemplateBinding IsEnabled, Converter={StaticResource BoolToOpacity}}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="18,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🧾" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Ver / Reimprimir" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="AnularVenta"
                    Height="40" Padding="18,0" FontSize="13"
                    IsEnabled="{Binding PuedeAnular}"
                    ToolTip="Supr - Anular venta">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background"      Value="#1AEF4444"/>
                        <Setter Property="Foreground"      Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="BorderBrush"     Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor"          Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="18,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✕" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Anular Venta" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
