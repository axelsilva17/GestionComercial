<UserControl x:Class="GestionComercial.UI.Views.Ventas.PagoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             xmlns:controls="clr-namespace:GestionComercial.UI.Views.Controls"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="PagoView_PreviewKeyDown">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>

        <!-- Estilos para botones de formas de pago (spec modulo-ventas-full) -->
        <Style x:Key="BotonPago" TargetType="Button">
            <Setter Property="Padding"      Value="12,14"/>
            <Setter Property="Margin"      Value="4"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BotonPagoSecundario" TargetType="Button" BasedOn="{StaticResource BotonPago}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid MaxWidth="700" Margin="0,40" VerticalAlignment="Top"
          HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="💳 Cobrar Venta"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding ClienteNombre}"
                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
            <!-- Estado del cobro -->
            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Esperando pago..."/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PuedeCobrar}" Value="True">
                                <Setter Property="Text" Value="✅ Listo para cobrar - Presione F6 o haga clic"/>
                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HayVuelto}" Value="True">
                                <Setter Property="Text" Value="💰 El cliente recibe vuelto"/>
                                <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Total a pagar -->
        <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="16" Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total de la venta -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalVenta, Converter={StaticResource DecimalToMoneda}}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Total pagado -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="PAGADO" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPagado, Converter={StaticResource DecimalToMoneda}}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Faltante / Vuelto -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="FALTA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HayVuelto}" Value="True">
                                        <Setter Property="Text" Value="VUELTO"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontSize="32" FontWeight="Bold" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="{Binding Faltante, Converter={StaticResource DecimalToMoneda}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HayVuelto}" Value="True">
                                        <Setter Property="Text"       Value="{Binding Vuelto, Converter={StaticResource DecimalToMoneda}}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Agregar pago -->
        <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="16" Padding="24,20">
            <StackPanel>
                <TextBlock Text="AGREGAR PAGO" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,14"/>

                <!-- Botones grandes de formas de pago -->
                <UniformGrid Rows="1" Margin="0,0,0,16">
                    <Button x:Name="AgregarEfectivo"
                            Height="50"
                            Background="{DynamicResource SurfaceBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="F1 - Efectivo">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💵" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Efectivo" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AgregarDebito"
                            Height="50"
                            Background="{DynamicResource SurfaceBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="F2 - Débito">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Débito" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AgregarCredito"
                            Height="50"
                            Background="{DynamicResource SurfaceBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="F3 - Crédito">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="Crédito" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AgregarQR"
                            Height="50"
                            Background="{DynamicResource SurfaceBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="F4 - QR">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📱" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="QR" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <!-- Monto a ingresar -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Monto -->
                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Height="44" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="$" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="MontoIngresado" Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="18" FontWeight="Bold"
                                     TextAlignment="Right"
                                     VerticalContentAlignment="Center"
                                     MaxLength="15"
                                     Text="{Binding MontoIngresado, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewTextInput="MontoIngresado_PreviewTextInput"
                                     KeyDown="MontoIngresado_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Botón agregar pago -->
                    <Button Grid.Column="2" x:Name="AgregarPago"
                            Height="44" Padding="18,0" FontSize="13"
                            Style="{StaticResource PrimaryButton}"
                            cal:Message.Attach="[Event Click] = [Action AgregarPago]">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="14" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Agregar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Botón completar con efectivo rápido -->
                <Button x:Name="CompletarConEfectivo"
                        Height="44" Margin="0,12,0,0"
                        Style="{StaticResource BotonPagoSecundario}"
                        ToolTip="F5 - Completar con efectivo"
                        cal:Message.Attach="[Event Click] = [Action CompletarConEfectivo]">
                    <Button.Visibility>
                        <Binding Path="HayFaltante" Converter="{StaticResource BoolToVisibility}"/>
                    </Button.Visibility>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💵" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Completar faltante en efectivo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Líneas de pago agregadas -->
        <Border Grid.Row="6" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="16" Padding="24,16"
                Visibility="{Binding Pagos.Count, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="PAGOS REGISTRADOS" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Pagos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="15"
                                           Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="💳"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsEfectivo}" Value="True">
                                                    <Setter Property="Text" Value="💵"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding NombreMetodo}"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Monto, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="4" x:Name="QuitarPago"
                                        Width="28" Height="28" FontSize="11"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource ErrorBrush}"
                                        Cursor="Hand"
                                        cal:Message.Attach="[Event Click] = [Action QuitarPago($dataContext)]"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Error + Botones finales -->
        <StackPanel Grid.Row="8" Orientation="Vertical">
            <Border Background="#1AEF4444" BorderBrush="{DynamicResource ErrorBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource ErrorBrush}" FontSize="13"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="Cancelar"
                        Height="48" FontSize="14" Content="← Volver a la venta"
                        ToolTip="Escape - Volver"
                        cal:Message.Attach="[Event Click] = [Action Cancelar]">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
                            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor"          Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" x:Name="Confirmar"
                        Height="48" FontSize="14" FontWeight="SemiBold"
                        IsEnabled="{Binding PuedeCobrar}"
                        ToolTip="F6 - Confirmar cobro"
                        cal:Message.Attach="[Event Click] = [Action Confirmar]">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Confirmar Cobro" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Botón Ver Historial (after sale completed) -->
            <Button Content="📋 Ver Historial"
                    Click="VerHistorial_Click"
                    Margin="0,12,0,0"
                    Height="40"
                    Padding="16,0"
                    Background="Transparent"
                    Foreground="{DynamicResource PrimaryBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    Visibility="{Binding VentaCompletada, Converter={StaticResource BoolToVisibility}}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="12,8">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Popup Historial (shared HistorialControl) -->
        <Grid x:Name="HistorialPopup" Visibility="{Binding MostrarHistorial, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="100" Background="#80000000">
            <Border Background="{DynamicResource CardBrush}" 
                    CornerRadius="12" Padding="24"
                    MaxWidth="800" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <controls:HistorialControl/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
