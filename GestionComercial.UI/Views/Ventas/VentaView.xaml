<UserControl x:Class="GestionComercial.UI.Views.Ventas.VentaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             xmlns:ventas="clr-namespace:GestionComercial.UI.ViewModels.Ventas"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="VentaView_PreviewKeyDown">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:NullVisibilityConverter   x:Key="NullToVisibility"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibility"/>
    

        <Style x:Key="ItemRow" TargetType="DataGridRow">
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="rowBorder" Background="Transparent"
                                CornerRadius="8" Margin="4,2">
                            <DataGridCellsPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rowBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="rowBorder" Property="Background" Value="{DynamicResource PrimaryAlphaBrush}"/>
                                <Setter TargetName="rowBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="rowBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ItemsGrid" TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="None"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="SelectionUnit"         Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="RowHeight"             Value="56"/>
            <Setter Property="ColumnHeaderHeight"    Value="36"/>
            <Setter Property="RowStyle"              Value="{StaticResource ItemRow}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor"          Value="Arrow"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="12,0" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilos para botones de formas de pago (spec modulo-ventas-full) -->
        <Style x:Key="BotonPago" TargetType="Button">
            <Setter Property="Padding"      Value="12,14"/>
            <Setter Property="Margin"      Value="4"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BotonPagoSecundario" TargetType="Button" BasedOn="{StaticResource BotonPago}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Popup de anulación (spec modulo-ventas-full) -->
        <Style x:Key="PopupAnulacionBorder" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="12"/>
            <Setter Property="Padding"        Value="24"/>
            <Setter Property="Width"          Value="400"/>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Height="849" Width="1204">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════
             COLUMNA 0 — Buscador + tabla de items
        ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="24,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

                <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título y cliente -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Nueva Venta"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Sin cliente asignado"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClienteNombre, Converter={StaticResource StringNotEmptyToVisibility}}"
                                                 Value="Visible">
                                        <Setter Property="Text" Value="{Binding ClienteNombre}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Botón Historial (antes mal ubicado como "Volver") -->
                <Button Grid.Column="1"
                        Content="📋 Historial"
                        Click="VerHistorial_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource PrimaryBrush}"
                        FontSize="14" Cursor="Hand" VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        ToolTip="Ver historial de ventas">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="10,8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Botón seleccionar cliente -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="4,2" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="F4" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="SeleccionarCliente"
                            Height="40" Padding="16,0" FontSize="13"
                            VerticalAlignment="Center"
                            cal:Message.Attach="[Event Click] = [Action SeleccionarCliente]">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
                            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor"          Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" FontSize="13" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Seleccionar Cliente" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>

            <!-- Buscador de productos -->
            <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="BusquedaProductoBorder" Grid.Column="0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Height="44">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center"
                                       Margin="12,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="BusquedaProducto" Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="14" VerticalContentAlignment="Center"
                                     Text="{Binding BusquedaProducto, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="0,0,12,0"/>
                        </Grid>
                    </Border>

                    <Button x:Name="AgregarProducto" Grid.Column="2"
                            Height="44" Padding="20,0" FontSize="13"
                            Style="{StaticResource PrimaryButton}" Grid.ColumnSpan="2" Margin="10,0,0,0"
                            ToolTip="F6 - Agregar producto"
                            cal:Message.Attach="[Event Click] = [Action AgregarProducto]">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Agregar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        <!-- ══════════════════════════════════════════════════════
             POPUP DE AUTOCOMPLETADO DE PRODUCTOS (Z-Index alto)
        ═══════════════════════════════════════════════════════ -->
        <Popup x:Name="PopupBusqueda"
               IsOpen="{Binding MostrarPopupBusqueda}"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=BusquedaProductoBorder}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Panel.ZIndex="999">
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Width="{Binding ElementName=BusquedaProductoBorder, Path=ActualWidth}"
                        MaxHeight="280"
                        Margin="0,4,0,0">
                    <Grid>
                        <!-- Loading indicator -->
                        <TextBlock Text="🔍 Buscando..."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="16"
                                   Visibility="{Binding BuscandoProductos, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Lista de resultados -->
                        <ListBox x:Name="ResultadosBusquedaList"
                                 ItemsSource="{Binding ResultadosBusqueda}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MouseDoubleClick="ResultadosBusquedaList_MouseDoubleClick"
                                 KeyDown="ResultadosBusquedaList_KeyDown"
                                 Visibility="{Binding BuscandoProductos, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="border"
                                                        Background="Transparent"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4"
                                                        Margin="4,2">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{DynamicResource PrimaryAlphaBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Nombre}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding CodigoBarra}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding PrecioVentaActual, Converter={StaticResource DecimalToMoneda}}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,2,0,0">
                                                <Run Text="Stock:"/>
                                                <Run Text="{Binding StockActual}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Mensaje sin resultados -->
                        <Border Visibility="{Binding HaySinResultados, Converter={StaticResource BoolToVisibility}}"
                                Padding="16" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" Margin="0,12">
                                <TextBlock Text="🔍"
                                           FontSize="24" HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="No se encontraron productos"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="¿Crear nuevo producto?"
                                           FontSize="12"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Popup>

            <!-- Tabla de items -->
            <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" ClipToBounds="True">
                <Grid>
                    <DataGrid x:Name="ItemSeleccionado"
                              ItemsSource="{Binding Items}"
                              Margin="4,4">
                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource ItemsGrid}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center" Margin="0,60">
                                                        <TextBlock Text="🛒" FontSize="48"
                                                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                                        <TextBlock Text="Sin productos agregados"
                                                                   FontSize="16" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Buscá un producto y presioná Agregar"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="PRODUCTO" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding ProductoNombre}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CodigoBarra}"
                                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Cantidad editable -->
                            <DataGridTemplateColumn Header="CANTIDAD" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="−" Width="28" Height="28" FontSize="16"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand"
                                                    Command="{Binding DataContext.RestarCantidadCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="{Binding Cantidad}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="10,0"/>
                                            <Button Content="＋" Width="28" Height="28" FontSize="14"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand"
                                                    Command="{Binding DataContext.SumarCantidadCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="P. UNITARIO" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PrecioUnitario, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="SUBTOTAL" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Subtotal, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Quitar item -->
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="30" Height="30" FontSize="12"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                Cursor="Hand" HorizontalAlignment="Center"
                                                Command="{Binding DataContext.QuitarItemCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             COLUMNA 2 — Panel totales + cobrar
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid Margin="22,24,22,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título panel -->
                <TextBlock Grid.Row="0"
                           Text="RESUMEN"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,20"/>

                <!-- Lista items resumen -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ProductoNombre}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding Cantidad}"/>
                                                <Run Text=" x "/>
                                                <Run Text="{Binding PrecioUnitario, Converter={StaticResource DecimalToMoneda}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Subtotal, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Totales + botón cobrar -->
                <StackPanel Grid.Row="2">
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Subtotal" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalBruto, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Descuento" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalDescuento, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="13" Foreground="{DynamicResource ErrorBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,4,0,16"/>

                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="TOTAL" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalFinal, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Descuento manual -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,0" Margin="0,0,0,12" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DescuentoManual" Grid.Column="0"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13" VerticalContentAlignment="Center"
                                     TextAlignment="Left"
                                     Text="{Binding DescuentoManual, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="% desc."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Botón cobrar -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="4,2" Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="F2" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <Button x:Name="IrACobrar"
                            Height="52" FontSize="15" FontWeight="SemiBold"
                            IsEnabled="{Binding CanIrACobrar}"
                            Style="{StaticResource PrimaryButton}"
                            cal:Message.Attach="[Event Click] = [Action IrACobrar]">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="18"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="COBRAR" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Botón anular venta (solo visible cuando hay venta activa) -->
                    <Button x:Name="MostrarAnulacion"
                            Height="44" FontSize="13"
                            Margin="0,8,0,0"
                            Style="{StaticResource BotonPagoSecundario}"
                            Visibility="{Binding HayVentaActiva, Converter={StaticResource BoolToVisibility}}"
                            cal:Message.Attach="[Event Click] = [Action MostrarAnulacion]">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Anular Venta" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             POPUP DE ANULACIÓN (spec modulo-ventas-full)
        ═══════════════════════════════════════════════════════ -->
        <Popup x:Name="AnulacionPopup"
               IsOpen="{Binding MostrarPopupAnulacion}"
               Placement="Center"
               PlacementTarget="{Binding ElementName=RootGrid}"
               StaysOpen="False">
            <Grid Background="#80000000" Width="1204" Height="849">
                <Border Style="{StaticResource PopupAnulacionBorder}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⚠ Anulación de Venta"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Motivo de anulación:"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,8"/>

                        <TextBox Text="{Binding MotivoAnulacion, UpdateSourceTrigger=PropertyChanged}"
                                 Height="100"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Padding="12"/>

                        <TextBlock Text="Este acción no se puede deshacer."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,8,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding CerrarPopupAnulacionCommand}"
                                    Height="44" FontSize="13"
                                    Content="Cancelar"
                                    Style="{StaticResource BotonPagoSecundario}"/>

                            <Button Grid.Column="2"
                                    Command="{Binding AnularVentaCommand}"
                                    Height="44" FontSize="13" FontWeight="SemiBold"
                                    Content="Confirmar Anulación"
                                    Background="{DynamicResource ErrorBrush}">
                                <Button.Foreground>
                                    <SolidColorBrush Color="White"/>
                                </Button.Foreground>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="10" Padding="12,14">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <!-- Popup Historial de Ventas -->
        <Grid x:Name="HistorialPopup" Visibility="{Binding MostrarHistorial, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="100" Background="#80000000">
            <Border Background="White" CornerRadius="8" Padding="20"
                    MaxWidth="800" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Historial de Ventas" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding HistorialVentas}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat='dd/MM/yyyy HH:mm'}" Width="120"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalFinal, StringFormat='$ {0:N0}'}" Width="100"/>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <Button Grid.Row="2" Content="Cerrar" Click="CerrarHistorial_Click"
                            HorizontalAlignment="Right" Margin="0,16,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
