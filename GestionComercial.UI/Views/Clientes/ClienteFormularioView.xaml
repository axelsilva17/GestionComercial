<UserControl x:Class="GestionComercial.UI.Views.Clientes.ClienteFormularioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FormField" TargetType="TextBox">
            <Setter Property="Height"                   Value="42"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Background"               Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused"    Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,20" MaxWidth="700">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Volver"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        FontSize="13" Cursor="Hand" VerticalAlignment="Center"
                        Margin="0,0,20,0" Click="Volver_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="10,6">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TituloFormulario, Mode=OneWay}" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SubtituloFormulario, Mode=OneWay}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- FORMULARIO -->
            <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="14" Padding="24">
                <StackPanel>
                    <TextBlock Text="DATOS DEL CLIENTE" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nombre -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="NOMBRE Y APELLIDO *" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FormField}"
                                     Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Documento -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="NÚMERO DE DOCUMENTO *" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FormField}"
                                     Text="{Binding Documento, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Teléfono -->
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="TELÉFONO" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FormField}"
                                     Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FormField}"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Email warning -->
                        <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                                Background="#15EF4444" BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12,8" Height="38"
                                Visibility="{Binding EmailInvalido, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="⚠  El email no tiene un formato válido (debe contener @)"
                                       Foreground="{DynamicResource ErrorBrush}" FontSize="12" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Activo -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Height="42" Padding="14,0" Margin="0,16,0,0">
                        <CheckBox Content="Cliente activo" FontSize="14"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  VerticalAlignment="Center" IsChecked="{Binding Activo}"/>
                    </Border>

                    <!-- Error general -->
                    <Border Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}"
                            Background="#15EF4444" BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠  " Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ACCIONES -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="3"
                                 Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"
                                 Background="{DynamicResource SurfaceBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="Guardando..." Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Cancelar" Style="{StaticResource GhostButton}"
                        Height="42" Padding="24,0" FontSize="14" Click="Cancelar_Click"/>

                <Button Grid.Column="3" Content="Guardar Cliente"
                        Style="{StaticResource PrimaryButton}"
                        Height="42" Padding="28,0" FontSize="14"
                        IsEnabled="{Binding CanGuardar}"
                        Click="Guardar_Click"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
