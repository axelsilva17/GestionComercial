<UserControl x:Class="GestionComercial.UI.Controles.BuscadorProducto"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Grid>
        <!-- Input de búsqueda -->
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Height="40" Panel.ZIndex="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔍" FontSize="15"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <Grid Grid.Column="1">
                    <TextBox x:Name="TxtBusqueda"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Background="Transparent" BorderThickness="0"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             FontSize="13" VerticalAlignment="Center"
                             TextChanged="TxtBusqueda_TextChanged"
                             KeyDown="TxtBusqueda_KeyDown"
                             LostFocus="TxtBusqueda_LostFocus"/>
                    <TextBlock x:Name="PlaceholderBusqueda"
                               Text="Buscar producto por nombre o código..."
                               FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtBusqueda}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" x:Name="BtnLimpiar" Content="✕"
                        FontSize="11" Width="30" Margin="0,0,4,0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Visibility="Collapsed" Click="BtnLimpiar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4" Padding="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Lista desplegable de resultados -->
        <Border x:Name="Dropdown" Visibility="Collapsed"
                VerticalAlignment="Top" Margin="0,44,0,0"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Panel.ZIndex="999"
                MaxHeight="280">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.25" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <!-- Resultados -->
                <ScrollViewer x:Name="ScrollResultados" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListaResultados" Padding="6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="item" Background="Transparent"
                                        CornerRadius="8" Padding="10,8" Cursor="Hand"
                                        MouseLeftButtonDown="ItemResultado_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nombre}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="Cód: " FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding CodigoBarra}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" · " FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="Stock: " FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding StockActual}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="$ {0:N0}">
                                                    <Binding Path="PrecioVentaActual"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Sin resultados -->
                <TextBlock x:Name="TxtSinResultados" Text="Sin resultados"
                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Padding="16"
                           Visibility="Collapsed"/>

                <!-- Cargando -->
                <StackPanel x:Name="PnlCargando" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="12" Visibility="Collapsed">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="2"
                                 Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"/>
                    <TextBlock Text=" Buscando..." FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
