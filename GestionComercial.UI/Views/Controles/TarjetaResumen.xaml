<UserControl x:Class="GestionComercial.UI.Controles.TarjetaResumen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12" Padding="16,14">
        <StackPanel>
            <!-- Encabezado: ícono + título -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="34" Height="34" CornerRadius="8"
                        Background="{Binding AcentoFondo, ElementName=Root}">
                    <TextBlock Text="{Binding Icono, ElementName=Root}"
                               FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding Titulo, ElementName=Root}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Valor principal -->
            <TextBlock Text="{Binding Valor, ElementName=Root}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{Binding ColorValor, ElementName=Root}"/>

            <!-- Subtítulo / variación -->
            <TextBlock Text="{Binding Subtitulo, ElementName=Root}"
                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
