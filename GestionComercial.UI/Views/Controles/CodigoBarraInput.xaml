<UserControl x:Class="GestionComercial.UI.Controles.CodigoBarraInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="8" Height="40">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Ícono escáner -->
            <TextBlock Grid.Column="0" Text="▦" FontSize="16"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Input -->
            <Grid Grid.Column="1">
                <TextBox x:Name="TxtCodigo"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Background="Transparent" BorderThickness="0"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         FontSize="14" VerticalAlignment="Center"
                         KeyDown="TxtCodigo_KeyDown"
                         TextChanged="TxtCodigo_TextChanged"/>
                <TextBlock Text="{Binding Placeholder, ElementName=Root}"
                           FontSize="13" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtCodigo}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Botón limpiar -->
            <Button Grid.Column="2" x:Name="BtnLimpiar" Content="✕"
                    FontSize="11" Width="30" Height="24" Margin="0,0,4,0"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    Visibility="Collapsed" Click="BtnLimpiar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</UserControl>
