<UserControl x:Class="GestionComercial.UI.Controles.SelectorCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="280">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Caja de búsqueda -->
        <Grid>
            <TextBox x:Name="TxtBusqueda"
                     Height="32"
                     Padding="8,0,32,0"
                     VerticalContentAlignment="Center"
                     TextChanged="TxtBusqueda_TextChanged"
                     KeyDown="TxtBusqueda_KeyDown"
                     LostFocus="TxtBusqueda_LostFocus"/>

            <!-- Botón limpiar -->
            <Button x:Name="BtnLimpiar"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Right"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    Click="BtnLimpiar_Click"
                    Content="✕"
                    Background="Transparent"
                    BorderThickness="0"/>
        </Grid>

        <!-- Dropdown -->
        <Border x:Name="Dropdown"
                Grid.Row="1"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed"
                Margin="0,2,0,0">

            <Grid MaxHeight="250">

                <!-- Loading -->
                <StackPanel x:Name="PnlCargando"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            Margin="10">
                    <TextBlock Text="Buscando..."
                               Foreground="Gray"/>
                </StackPanel>

                <!-- Sin resultados -->
                <TextBlock x:Name="TxtSinResultados"
                           Text="Sin resultados"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"
                           Margin="10"/>

                <!-- Lista resultados -->
                <ListBox x:Name="ListaResultados"
                         Visibility="Collapsed"
                         BorderThickness="0"
                         Background="Transparent">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="ItemResultado_Click">
                                <StackPanel>
                                    <TextBlock Text="{Binding Nombre}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Documento}"
                                               FontSize="11"
                                               Foreground="Gray"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </Grid>
        </Border>
    </Grid>
</UserControl>