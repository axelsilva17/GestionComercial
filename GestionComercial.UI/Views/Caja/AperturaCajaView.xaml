<UserControl x:Class="GestionComercial.UI.Views.Caja.AperturaCajaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
            <Border MaxWidth="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="16" Padding="36,32" Margin="0,24">
                <StackPanel>

                    <!-- ── Header ─────────────────────────────────────────── -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                        <Border Width="60" Height="60" CornerRadius="15"
                                Background="#1A10B981" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="🔓" FontSize="28"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Apertura de Caja" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SucursalNombre}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding FechaHoy, StringFormat='dd/MM/yyyy   HH:mm'}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- ── Último cierre ──────────────────────────────────── -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="16,14" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ÚLTIMO CIERRE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding UltimoCierre, StringFormat='dd/MM/yyyy  HH:mm'}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}" Width="1" Margin="0,4"/>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="SALDO ANTERIOR" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding SaldoAnterior, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Right" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Selección de Caja y Turno ─────────────────────────── -->
                    <!-- Caja -->
                    <TextBlock Text="SELECCIONAR CAJA" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding CajasDisponibles}"
                              SelectedItem="{Binding CajaSeleccionada}"
                              DisplayMemberPath="Nombre"
                              Margin="0,0,0,16"/>

                    <!-- Turno -->
                    <TextBlock Text="TURNO" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Turnos}"
                              SelectedItem="{Binding TurnoSeleccionado}"
                              Margin="0,0,0,20"/>

                    <!-- ── Monto inicial ──────────────────────────────────── -->
                    <TextBlock Text="MONTO INICIAL EN CAJA" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                            CornerRadius="10" Margin="0,0,0,6">
                        <Grid Height="58">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="$" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       VerticalAlignment="Center" Margin="16,0,8,0"/>
                             <TextBox x:Name="MontoInicial" Grid.Column="1"
                                     Text="{Binding MontoInicial, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="24" FontWeight="Bold"
                                     VerticalContentAlignment="Center" Padding="0,0,16,0"
                                     CaretBrush="{DynamicResource PrimaryBrush}"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Ingresá el efectivo físico con el que abrís el turno"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,24"/>



                    <!-- ── Botones ────────────────────────────────────────── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="Cancelar" Grid.Column="0"
                                Content="Cancelar" Height="48" FontSize="14"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="Confirmar" Grid.Column="2" Height="48" FontSize="14"
                                FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{DynamicResource SuccessBrush}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#CC10B981"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <ProgressBar IsIndeterminate="True" Width="14" Height="14"
                                             Margin="0,0,8,0" BorderThickness="0"
                                             Foreground="White" Background="Transparent"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="Abrir Caja" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
