<UserControl x:Class="GestionComercial.UI.Views.Caja.CierreCajaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
    </UserControl.Resources>

    <Grid>
        <Border MaxWidth="520" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="16" Padding="36,32">
            <StackPanel>
                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border Width="56" Height="56" CornerRadius="14"
                            Background="#1AEF4444" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="🔒" FontSize="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Cierre de Caja" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding SucursalNombre}"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Resumen del turno -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="20,16" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="RESUMEN DEL TURNO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Monto inicial" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding MontoInicial, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Total ingresos" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalIngresos, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="13" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Total egresos" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalEgresos, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="13" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Ventas del turno" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalVentas, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="13" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,4,0,12"/>
                        <Grid>
                            <TextBlock Text="SALDO ESPERADO" FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SaldoEsperado, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Monto físico contado -->
                <TextBlock Text="EFECTIVO CONTADO EN CAJA" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Margin="0,0,0,6">
                    <Grid Height="56">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="$" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <TextBox x:Name="MontoFinal" Grid.Column="1"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontSize="22" FontWeight="Bold"
                                 VerticalContentAlignment="Center" Padding="0,0,16,0"/>
                    </Grid>
                </Border>

                <!-- Diferencia -->
                <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1A0F172A"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DiferenciaNegativa}" Value="True">
                                    <Setter Property="Background" Value="#1AEF4444"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DiferenciaNegativa}" Value="False">
                                    <Setter Property="Background" Value="#1A22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <TextBlock Text="Diferencia" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Diferencia, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Right">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DiferenciaNegativa}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Observaciones -->
                <TextBlock Text="OBSERVACIONES" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,20">
                    <TextBox x:Name="Observacion"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="13" TextWrapping="Wrap" AcceptsReturn="True"
                             Height="60" VerticalContentAlignment="Top"/>
                </Border>

                <!-- Error -->
                <Border Background="#1AEF4444" BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                        Visibility="{Binding TieneError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                               Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
                </Border>

                <!-- Botones -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="Cancelar" Grid.Column="0"
                            Content="Cancelar" Height="46" FontSize="14"
                            Background="{DynamicResource SurfaceBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="Confirmar" Grid.Column="2"
                            Height="46" FontSize="14"
                            Background="#1AEF4444" BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1" Foreground="{DynamicResource ErrorBrush}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#33EF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <ProgressBar IsIndeterminate="True" Width="14" Height="14"
                                         Margin="0,0,8,0" BorderThickness="0"
                                         Foreground="{DynamicResource ErrorBrush}" Background="Transparent"
                                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="Cerrar Caja" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
