<UserControl x:Class="GestionComercial.UI.Views.Caja.CierreCajaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <Style x:Key="FilaResumen" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
            <Border MaxWidth="560" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="16" Padding="36,32" Margin="0,24">
                <StackPanel>

                    <!-- ── Header ─────────────────────────────────────────── -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border Width="60" Height="60" CornerRadius="15"
                                Background="#1AEF4444" HorizontalAlignment="Center" Margin="0,0,0,14">
                            <TextBlock Text="🔒" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Cierre de Caja" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SucursalNombre}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                            <TextBlock Text="{Binding FechaApertura, StringFormat='Apertura: dd/MM/yyyy HH:mm'}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="  |  " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding FechaCierre, StringFormat='Cierre: dd/MM/yyyy HH:mm'}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Center" Margin="0,3,0,0">
                            <Run Text="Transacciones: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Run Text="{Binding CantidadVentas}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- ── Sección 1: Lo que mueve la caja física ─────────── -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="6" CornerRadius="3"
                                        Background="{DynamicResource SuccessBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="MOVIMIENTOS DE EFECTIVO" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Monto inicial -->
                            <Grid Style="{StaticResource FilaResumen}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Monto inicial" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding MontoInicial, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>

                            <!-- Ventas en efectivo -->
                            <Grid Style="{StaticResource FilaResumen}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource SuccessBrush}"
                                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Ventas en efectivo" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding VentasEfectivo, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"/>
                            </Grid>

                            <!-- Ingresos manuales -->
                            <Grid Style="{StaticResource FilaResumen}"
                                  Visibility="{Binding IngresosEfectivo, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource SuccessBrush}"
                                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Ingresos manuales" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding IngresosEfectivo, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"/>
                            </Grid>

                            <!-- Egresos manuales -->
                            <Grid Style="{StaticResource FilaResumen}"
                                  Visibility="{Binding EgresosEfectivo, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource ErrorBrush}"
                                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Egresos manuales" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding EgresosEfectivo, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,4,0,14"/>

                            <!-- Saldo en caja -->
                            <Border Background="#1510B981" BorderBrush="{DynamicResource SuccessBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="SALDO EN CAJA" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource SuccessBrush}"/>
                                        <TextBlock Text="Calculado por el sistema" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SaldoEsperado, Converter={StaticResource DecimalToMoneda}}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Sección 2: Otros métodos (excluye efectivo) ─────────── -->
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="20,16" Margin="0,0,0,12"
                            Visibility="{Binding HayOtrosMetodos, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="6" CornerRadius="3"
                                        Background="{DynamicResource InfoBrush}" Margin="0,0,10,0"/>
                                <TextBlock Text="OTROS MÉTODOS DE PAGO" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Montos que se acreditan por separado"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,14" TextWrapping="Wrap"/>

                            <!-- Lista dinámica por método (solo no-efectivo) -->
                            <ItemsControl ItemsSource="{Binding Desglose}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8" Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="8" Height="8" CornerRadius="4"
                                                        Background="{DynamicResource InfoBrush}"
                                                        VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Metodo}" FontSize="13"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,4,0,12"/>

                            <!-- Total vendido -->
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Total vendido en el turno" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalVendido, Converter={StaticResource DecimalToMoneda}}"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Diferencia calculada internamente ──────────────────────── -->
                    <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiferenciaNegativa}" Value="True">
                                        <Setter Property="Background"  Value="#1AEF4444"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DiferenciaNegativa}" Value="False">
                                        <Setter Property="Background"  Value="#1A10B981"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="RESULTADO DEL CIERRE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding DiferenciaTexto}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Diferencia, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DiferenciaNegativa}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- ── Observaciones ──────────────────────────────────── -->
                    <TextBlock Text="OBSERVACIONES (opcional)" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="12,10" Margin="0,0,0,20">
                         <TextBox x:Name="Observacion" Background="Transparent" BorderThickness="0"
                                  Text="{Binding Observacion, UpdateSourceTrigger=PropertyChanged}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontSize="13" TextWrapping="Wrap" AcceptsReturn="True"
                                  Height="64" VerticalContentAlignment="Top"
                                  CaretBrush="{DynamicResource PrimaryBrush}"/>
                    </Border>

                    <!-- ── Error ──────────────────────────────────────────── -->
                    <Border Background="#1AEF4444" BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                            Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                   Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
                    </Border>

                    <!-- ── Botones ────────────────────────────────────────── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Cancelar" Grid.Column="0" Content="Cancelar" Height="48" FontSize="14"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="Confirmar" Grid.Column="2" Height="48" FontSize="14"
                                FontWeight="SemiBold" Cursor="Hand"
                                cal:Message.Attach="[Event Click] = [Action ConfirmarCiego]">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{DynamicResource ErrorBrush}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#CCEF4444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <ProgressBar IsIndeterminate="True" Width="14" Height="14" Margin="0,0,8,0"
                                             BorderThickness="0" Foreground="White" Background="Transparent"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="Cerrar Caja" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
