<UserControl x:Class="GestionComercial.UI.Views.Caja.RegistrarIngresoEgresoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter      x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid MinWidth="380" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <Border Width="56" Height="56" CornerRadius="14"
                    HorizontalAlignment="Center" Margin="0,0,0,14">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#1A22C55E"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EsEgreso}" Value="True">
                                <Setter Property="Background" Value="#1AEF4444"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="26">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="↑"/>
                            <Setter Property="Foreground" Value="#22C55E"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EsEgreso}" Value="True">
                                    <Setter Property="Text" Value="↓"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
            <TextBlock Text="{Binding Titulo}" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ── Tipo: Ingreso / Egreso ──────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <RadioButton x:Name="RbIngreso" Grid.Column="0"
                         IsChecked="{Binding EsIngreso, Mode=TwoWay}"
                         GroupName="TipoMovimiento"
                         Cursor="Hand">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="16,12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="↑" FontSize="18" FontWeight="Bold"
                                           Foreground="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Ingreso" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A22C55E"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#22C55E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
            </RadioButton>

            <RadioButton x:Name="RbEgreso" Grid.Column="2"
                         IsChecked="{Binding EsEgreso, Mode=TwoWay}"
                         GroupName="TipoMovimiento"
                         Cursor="Hand">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="16,12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="↓" FontSize="18" FontWeight="Bold"
                                           Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Egreso" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AEF4444"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
            </RadioButton>
        </Grid>

        <!-- ── Monto ──────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="MONTO" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10" Padding="4,2">
                <Grid Height="52">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="$" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,8,0"/>
                    <TextBox x:Name="TxtMonto" Grid.Column="1"
                             Text="{Binding Monto, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="26" FontWeight="Bold"
                             VerticalContentAlignment="Center"
                             CaretBrush="{DynamicResource PrimaryBrush}"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ── Descripción ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="DESCRIPCIÓN / OBSERVACIÓN" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="10">
                <TextBox x:Name="TxtDescripcion"
                         Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         FontSize="14"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="80" Padding="14,12"
                         VerticalContentAlignment="Top"
                         CaretBrush="{DynamicResource PrimaryBrush}"/>
            </Border>
        </StackPanel>

        <!-- ── Error ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="7" Background="#1AEF4444"
                BorderBrush="{DynamicResource ErrorBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12,10"
                Visibility="{Binding TieneError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                       Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
        </Border>

        <!-- ── Botones ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancelar" Height="48" FontSize="14"
                    Background="{DynamicResource SurfaceBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Cursor="Hand"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                    cal:Message.Attach="Cancelar">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" Height="48" FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand"
                    cal:Message.Attach="Guardar">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#22C55E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EsEgreso}" Value="True">
                                            <Setter Property="Background" Value="#EF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="14" Height="14"
                                             Margin="0,0,8,0" BorderThickness="0"
                                             Foreground="White" Background="Transparent"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="Guardar" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</UserControl>
