<UserControl x:Class="GestionComercial.UI.Views.Productos.ImportacionProductosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:ProgresoPorcentajeConverter x:Key="ProgresoPorcentaje"/>
        <Style x:Key="OpcionCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
        <Style x:Key="StepCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="24"/>
            <Setter Property="Margin"          Value="0,0,0,16"/>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24" MaxWidth="820">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Importar Productos desde Excel" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Cargá masivamente productos con su stock, precios y categorías"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- ✅ Click conectado -->
                <Button Grid.Column="1" Style="{StaticResource GhostBtn}"
                        Height="38" Padding="14,0" FontSize="12"
                        Click="DescargarPlantilla_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬇ " FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Descargar plantilla" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <StackPanel Grid.Row="2">

                <!-- ══ PASO 1: DROPZONE ══ -->
                <Border Style="{StaticResource StepCard}"
                        Visibility="{Binding MostrarDropzone, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                                <TextBlock Text="1" FontSize="13" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Seleccioná el archivo Excel" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                                CornerRadius="12" Padding="0,40" Cursor="Hand"
                                AllowDrop="True"
                                Drop="DropZone_Drop"
                                DragOver="DropZone_DragOver"
                                MouseLeftButtonDown="DropZone_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center"/>
                                <TextBlock Text="Arrastrá el archivo aquí" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                <TextBlock Text="o hacé clic para seleccionar" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Formatos aceptados: .xlsx, .xls" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="OPCIONES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            <CheckBox Content="Actualizar precio y stock de productos existentes (por código de barra)"
                                      IsChecked="{Binding ActualizarExistentes}" Style="{StaticResource OpcionCheck}"/>
                            <CheckBox Content="Crear categorías nuevas automáticamente si no existen"
                                      IsChecked="{Binding CrearCategorias}" Style="{StaticResource OpcionCheck}"/>

                            <!-- Ajuste de precio -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="Ajustar precio (%):" VerticalAlignment="Center" Width="140"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding AjustePorcentaje, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="70" Style="{StaticResource Input}"/>
                                <TextBlock Text="%" VerticalAlignment="Center" Margin="4,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Margen sobre costo (%):" VerticalAlignment="Center" Width="140"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding Margen, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="70" Style="{StaticResource Input}"/>
                                <TextBlock Text="%" VerticalAlignment="Center" Margin="4,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Background="#1AEF4444" CornerRadius="8" Padding="12,8" Margin="0,8,0,0"
                                Visibility="{Binding TieneError, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding MensajeError}" FontSize="12"
                                       Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══ PASO 2: PREVIEW ══ -->
                <Border Style="{StaticResource StepCard}"
                        Visibility="{Binding MostrarPreview, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource PrimaryBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="2" FontSize="13" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Vista previa de datos" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding ArchivoNombre}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- ✅ Click conectado -->
                            <Button Grid.Column="1" Content="✎ Cambiar archivo"
                                    Style="{StaticResource GhostBtn}"
                                    Height="32" Padding="12,0" FontSize="11"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Click="Reiniciar_Click"/>
                        </Grid>

                        <!-- Badges resumen -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="#1A22C55E" CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                                <TextBlock FontSize="12" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold">
                                    <Run Text="✓ "/>
                                    <Run Text="{Binding FilasValidas}"/>
                                    <Run Text=" válidas"/>
                                </TextBlock>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                                <TextBlock FontSize="12" Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold">
                                    <Run Text="{Binding FilasConError}"/>
                                    <Run Text=" con error"/>
                                </TextBlock>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,6">
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="{Binding FilasTotales}"/>
                                    <Run Text=" total"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Tabla preview -->
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto" MaxHeight="320"/>
                                </Grid.RowDefinitions>

                                <!-- Header tabla con Padding en cada celda para separar MARGEN y CATEGORÍA -->
                                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="10"/>  <!-- separador -->
                                            <ColumnDefinition Width="82"/>
                                            <ColumnDefinition Width="72"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"  Text="#"         FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1"  Text="ESTADO"    FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="2"  Text="NOMBRE"    FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="3"  Text="P. VENTA"  FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="4"  Text="P. COSTO"  FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="5"  Text="STOCK"     FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="6"  Text="MÍNIMO"    FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="7"  Text="MARGEN"    FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                        <!-- Col 8 = espaciador vacío -->
                                        <TextBlock Grid.Column="9"  Text="CATEGORÍA" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="10" Text="UNIDAD"    FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Filas}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EsValida}" Value="False">
                                                                    <Setter Property="Background" Value="#08EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid Margin="12,7">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36"/>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="85"/>
                                                            <ColumnDefinition Width="85"/>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="82"/>
                                                            <ColumnDefinition Width="72"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding Fila}" FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>

                                                        <Border Grid.Column="1" CornerRadius="6" Padding="6,3"
                                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1A22C55E"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding EsValida}" Value="False">
                                                                            <Setter Property="Background" Value="#1AEF4444"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding EsNuevo}" Value="False">
                                                                            <Setter Property="Background" Value="#1A3B82F6"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding EstadoTexto}" FontSize="10" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EsValida}" Value="False">
                                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding EsNuevo}" Value="False">
                                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <TextBox Grid.Column="2" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Background="Transparent" BorderThickness="0"
                                                                   VerticalAlignment="Center" Padding="0"
                                                                   ToolTip="{Binding ErrorDescripcion}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ErrorDescripcion}" FontSize="10"
                                                                   Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                                                                   VerticalAlignment="Bottom" Margin="0,14,0,0"
                                                                   Visibility="{Binding EsValida, Converter={StaticResource BoolToVisibility}}"/>

                                                        <TextBox Grid.Column="3" TextAlignment="Right" FontSize="12" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Background="Transparent" BorderThickness="0"
                                                                   ToolTip="Precio de venta">
                                                            <TextBox.Text>
                                                                <Binding Path="PrecioVenta" StringFormat="C0" UpdateSourceTrigger="PropertyChanged">
                                                                    <Binding.FallbackValue>0</Binding.FallbackValue>
                                                                </Binding>
                                                            </TextBox.Text>
                                                        </TextBox>

                                                        <TextBox Grid.Column="4" TextAlignment="Right" FontSize="12" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Background="Transparent" BorderThickness="0"
                                                                   ToolTip="Precio de costo">
                                                            <TextBox.Text>
                                                                <Binding Path="PrecioCosto" StringFormat="C0" UpdateSourceTrigger="PropertyChanged">
                                                                    <Binding.FallbackValue>0</Binding.FallbackValue>
                                                                </Binding>
                                                            </TextBox.Text>
                                                        </TextBox>

                                                        <TextBox Grid.Column="5" Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}"
                                                                   FontSize="12" TextAlignment="Right" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Background="Transparent" BorderThickness="0"
                                                                   ToolTip="Stock actual"/>

                                                        <TextBox Grid.Column="6" Text="{Binding StockMinimo, UpdateSourceTrigger=PropertyChanged}"
                                                                   FontSize="12" TextAlignment="Right" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Background="Transparent" BorderThickness="0"
                                                                   ToolTip="Stock mínimo"/>

                                                        <TextBlock Grid.Column="7" FontSize="12" TextAlignment="Right"
                                                                   VerticalAlignment="Center" FontWeight="SemiBold">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:N1} %">
                                                                    <Binding Path="Margen"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Margen}" Value="0">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <!-- Col 8 = espaciador -->

                                                        <TextBlock Grid.Column="9" Text="{Binding Categoria}" FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center" TextWrapping="Wrap"/>

                                                        <TextBlock Grid.Column="10" Text="{Binding UnidadMedida}" FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="0" Grid.RowSpan="2" Background="{DynamicResource CardBrush}" Opacity="0.8"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                                <ProgressBar Grid.Row="0" Grid.RowSpan="2" IsIndeterminate="True" Height="3"
                                             VerticalAlignment="Top" Foreground="{DynamicResource PrimaryBrush}"
                                             BorderThickness="0"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </Border>

                        <!-- Barra progreso importación -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="16,12"
                                Margin="0,16,0,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Importando productos..." FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding TextoProgreso}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Barra progreso real con porcentaje -->
                                <Grid Height="24">
                                    <Border Background="{DynamicResource BorderBrush}" CornerRadius="4"/>
                                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="{Binding Progreso, Converter={StaticResource ProgresoPorcentaje}}"/>
                                    <TextBlock Text="{Binding Progreso, StringFormat={}{0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"
                                               Foreground="White" FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Botones preview -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <!-- ✅ Click conectado -->
                            <Button Content="Cancelar" Style="{StaticResource GhostBtn}"
                                    Height="38" Padding="16,0" Margin="0,0,8,0" FontSize="13"
                                    Click="Cancelar_Click"/>

                            <!-- ✅ Click conectado — este era el que no funcionaba -->
                            <Button Style="{StaticResource PrimaryButton}"
                                    Height="38" Padding="20,0" FontSize="13"
                                    IsEnabled="{Binding PuedeImportar}"
                                    Click="EjecutarImportacion_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬆ " FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="Importar "/>
                                        <Run Text="{Binding FilasValidas}"/>
                                        <Run Text=" productos"/>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ══ PASO 3: RESULTADO ══ -->
                <Border Style="{StaticResource StepCard}"
                        Visibility="{Binding MostrarResultado, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="✅" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Importación completada" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border Background="#1A22C55E" CornerRadius="10" Padding="20,12" Margin="6,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Importados}" FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Nuevos" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1A3B82F6" CornerRadius="10" Padding="20,12" Margin="6,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Actualizados}" FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Actualizados" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="20,12" Margin="6,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Omitidos}" FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Omitidos" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- ✅ Click conectado -->
                            <Button Content="Importar otro archivo" Style="{StaticResource GhostBtn}"
                                    Height="38" Padding="16,0" Margin="0,0,8,0" FontSize="13"
                                    Click="ReiniciarArchivo_Click"/>
                            <!-- ✅ Click conectado -->
                            <Button Style="{StaticResource PrimaryButton}"
                                    Height="38" Padding="20,0" FontSize="13"
                                    Content="Ir a Productos →"
                                    Click="Finalizar_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
