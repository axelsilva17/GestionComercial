<UserControl x:Class="GestionComercial.UI.Views.Productos.ProductoFormularioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FormField" TargetType="TextBox">
            <Setter Property="Height"                   Value="42"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Background"               Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>  <!-- Info producto -->
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>  <!-- Precios y stock -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>  <!-- Acciones -->
            </Grid.RowDefinitions>

            <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Volver -->
                    <ColumnDefinition Width="*"/>     <!-- Título -->
                    <ColumnDefinition Width="Auto"/>  <!-- Importar desde Excel -->
                </Grid.ColumnDefinitions>

                <!-- Volver -->
                <Button x:Name="VolverBtn" Grid.Column="0"
                        Content="← Volver"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        FontSize="13" Cursor="Hand" VerticalAlignment="Center"
                        Margin="0,0,20,0"
                        Click="Volver_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="10,6">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Título -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TituloFormulario, Mode=OneWay}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SubtituloFormulario, Mode=OneWay}"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- ── Importar desde Excel (solo visible en modo Crear) ── -->
                <Button x:Name="ImportarExcelBtn" Grid.Column="2"
                        Height="40" Padding="16,0" FontSize="13" Cursor="Hand"
                        VerticalAlignment="Center"
                        Visibility="{Binding MostrarBotonImportar, Converter={StaticResource BoolToVisibility}}"
                        Click="ImportarExcel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
                            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                <Setter TargetName="b" Property="BorderBrush"  Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬆ " FontSize="14" VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="Importar desde Excel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- SECCIÓN: INFORMACIÓN DEL PRODUCTO -->
            <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="24">
                <StackPanel>
                    <TextBlock Text="INFORMACIÓN DEL PRODUCTO" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nombre -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="NOMBRE *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="NombreField" Style="{StaticResource FormField}"
                                     Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- SKU -->
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="SKU" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SKUField" Style="{StaticResource FormField}"
                                         FontFamily="Consolas"
                                         Text="{Binding SKU, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button x:Name="GenerarSKUBtn" Grid.Column="1"
                                        Content="⟳" Style="{StaticResource IconBtn}"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Margin="8,0,0,0" ToolTip="Generar SKU automático"
                                        Click="GenerarSKU_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Código barras -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="CÓDIGO DE BARRAS" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CodigoBarraField" Style="{StaticResource FormField}"
                                         FontFamily="Consolas"
                                         Text="{Binding CodigoBarra, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1" Content="📷" Style="{StaticResource IconBtn}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Margin="8,0,0,0" ToolTip="Escanear código"/>
                            </Grid>
                        </StackPanel>

                        <!-- Categoría -->
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="CATEGORÍA *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CategoriaIdField" Height="42" FontSize="14"
                                      Background="{DynamicResource SurfaceBrush}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding Categorias}" DisplayMemberPath="Nombre"
                                      SelectedValuePath="Id"/>
                        </StackPanel>

                        <!-- Unidad -->
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="UNIDAD DE MEDIDA *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="UnidadMedidaIdField" Height="42" FontSize="14"
                                      Background="{DynamicResource SurfaceBrush}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding UnidadesMedida}" DisplayMemberPath="Nombre"
                                      SelectedValuePath="Id"/>
                        </StackPanel>

                        <!-- Activo -->
                        <StackPanel Grid.Row="4" Grid.Column="2" VerticalAlignment="Bottom">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Height="42" Padding="14,0">
                                <CheckBox x:Name="ActivoField" Content="Producto activo"
                                          FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding Activo}"/>
                            </Border>
                        </StackPanel>

                        <!-- Descripción -->
                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="DESCRIPCIÓN" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="DescripcionField"
                                     Height="80" Padding="12,10" FontSize="14"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{x:Null}">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,10"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SECCIÓN: PRECIOS Y STOCK -->
            <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="24">
                <StackPanel>
                    <TextBlock Text="PRECIOS Y STOCK" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Precio venta -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PRECIO DE VENTA *" Style="{StaticResource FieldLabel}"/>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Height="42">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="$" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               VerticalAlignment="Center" Margin="12,0,6,0"/>
                                    <TextBox x:Name="PrecioVentaField" Grid.Column="1"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="15" FontWeight="SemiBold"
                                             VerticalContentAlignment="Center"
                                             TextAlignment="Right" Padding="0,0,12,0"
                                             Text="{Binding PrecioVentaActual, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Precio costo -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PRECIO DE COSTO *" Style="{StaticResource FieldLabel}"/>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Height="42">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="$" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0,6,0"/>
                                    <TextBox x:Name="PrecioCostoField" Grid.Column="1"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="15" FontWeight="SemiBold"
                                             VerticalContentAlignment="Center"
                                             TextAlignment="Right" Padding="0,0,12,0"
                                             Text="{Binding PrecioCostoActual, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </Border>
                            <TextBlock Margin="0,6,0,0" FontSize="12">
                                <Run Text="Margen: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Run Text="{Binding MargenCalculado, Mode=OneWay}"
                                     Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Stock actual -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="STOCK ACTUAL" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="StockActualField" Style="{StaticResource FormField}"
                                     TextAlignment="Right" FontFamily="Consolas" FontSize="16"
                                     Text="{Binding StockActual, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Stock mínimo -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="STOCK MÍNIMO" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="StockMinimoField" Style="{StaticResource FormField}"
                                     TextAlignment="Right" FontFamily="Consolas" FontSize="16"
                                     Text="{Binding StockMinimo, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Alerta de reposición" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Error -->
                    <Border Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}"
                            Background="#15EF4444" BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠  " Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ACCIONES -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Loading -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="3"
                                 Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"
                                 Background="{DynamicResource SurfaceBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="Guardando..." Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="CancelarBtn" Grid.Column="1"
                        Content="Cancelar" Style="{StaticResource GhostButton}"
                        Height="42" Padding="24,0" FontSize="14"
                        Click="Cancelar_Click"/>

                <Button x:Name="GuardarBtn" Grid.Column="3"
                        Content="Guardar Producto"
                        Style="{StaticResource PrimaryButton}"
                        Height="42" Padding="28,0" FontSize="14"
                        IsEnabled="{Binding CanGuardar}"
                        Click="Guardar_Click"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
