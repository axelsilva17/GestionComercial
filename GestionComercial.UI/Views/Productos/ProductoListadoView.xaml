<UserControl x:Class="GestionComercial.UI.Views.Productos.ProductoListadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:NullVisibilityConverter   x:Key="NullToVisibility"/>
        <converters:EnumToIntConverter         x:Key="EnumToIntConverter"/>

        <Style x:Key="ProductoRow" TargetType="DataGridRow">
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="rowBorder" Background="Transparent"
                                CornerRadius="8" Margin="4,2">
                            <DataGridCellsPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rowBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="rowBorder" Property="Background" Value="{DynamicResource PrimaryAlphaBrush}"/>
                                <Setter TargetName="rowBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="rowBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProductosGrid" TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="None"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="SelectionUnit"         Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="RowHeight"             Value="54"/>
            <Setter Property="ColumnHeaderHeight"    Value="38"/>
            <Setter Property="RowStyle"              Value="{StaticResource ProductoRow}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor"          Value="Arrow"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="12,0" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SideValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,16"/>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL PRINCIPAL -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- METRICAS -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="TOTAL" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalProductos}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="productos" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="ACTIVOS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ProductosActivos}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="en catálogo" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="STOCK BAJO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ProductosStockBajo}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="requieren reposición" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="SIN STOCK" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ProductosSinStock}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="agotados" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

<!-- FILTROS -->
            <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="12,10"
                    xmlns:behaviors="clr-namespace:GestionComercial.UI.Views.Behaviors"
                    behaviors:ToolbarResponsiveBehavior.Enable="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Barra de búsqueda - responsive -->
                    <Border Grid.Column="0" x:Name="SearchBorder" 
                            behaviors:SearchBarResponsiveBehavior.Enable="True"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="6" 
                            Height="38" Width="450">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center"
                                       Margin="10,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="TextoBusqueda" Grid.Column="1"
                                     Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13" VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"
                                     KeyDown="TextoBusqueda_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Resto de filtros y botones con espaciado -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="CategoriaSeleccionada" Width="130" Height="38"
                                  Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding Categorias}" DisplayMemberPath="Nombre"
                                  SelectedItem="{Binding CategoriaSeleccionada}"/>

                        <Border Width="10" MinWidth="0"/>

                        <ComboBox x:Name="FiltroActivo" Width="90" Height="38"
                                  Style="{StaticResource FilterComboBoxStyle}"
                                  SelectedIndex="{Binding FiltroActivo}">
                            <ComboBoxItem Content="Todos"/>
                            <ComboBoxItem Content="Activos"/>
                            <ComboBoxItem Content="Inactivos"/>
                        </ComboBox>

                        <Border Width="12" MinWidth="0"/>

                        <Button Content="Buscar" Height="38" Padding="16,0"
                               Style="{StaticResource SecondaryButton}"
                               Click="Buscar_Click"/>
                        <Border Width="8" MinWidth="0"/>
                        <Button Content="⚡ Ajuste" Height="38" Padding="16,0"
                               Style="{StaticResource SecondaryButton}"
                               Click="AbrirAjusteMasivo_Click"/>
                        <Border Width="8" MinWidth="0"/>
                        <Button Content="+ Nuevo" Height="38" Padding="14,0"
                               Style="{StaticResource SecondaryButton}"
                               Click="NuevoProducto_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TABLA -->
            <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" ClipToBounds="True">
                <Grid>
                    <DataGrid x:Name="ProductosGrid"
                              Style="{StaticResource ProductosGrid}"
                              ItemsSource="{Binding Productos}"
                              SelectionChanged="ProductoSeleccionado_SelectionChanged"
                              Margin="0,0">
                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="CODIGO" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CodigoBarra}"
                                                   Margin="12,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   FontWeight="SemiBold" FontFamily="Consolas"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="PRODUCTO" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0">
                                            <Border Width="34" Height="34" CornerRadius="8"
                                                    Background="{DynamicResource SurfaceBrush}">
                                                <TextBlock Text="{Binding Inicial}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Nombre}"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding CategoriaNombre}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="P. VENTA" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PrecioVentaActual, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="P. COSTO" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PrecioCostoActual, Converter={StaticResource DecimalToMoneda}}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,16,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="STOCK" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StockActual}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="ESTADO" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="10,4"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="ACTIVO"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Activo}" Value="False">
                                                                <Setter Property="Text" Value="INACTIVO"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text=">" FontSize="16"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#CC0F172A" CornerRadius="12"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="180" Height="3"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         BorderThickness="0"
                                         Background="{DynamicResource SurfaceBrush}"/>
                            <TextBlock Text="Cargando..."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- PAGINACION -->
            <Grid Grid.Row="5" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                    <Run Text="Mostrando "/>
                    <Run Text="{Binding ProductosMostrados, Mode=OneWay}" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Run Text=" de "/>
                    <Run Text="{Binding TotalProductos, Mode=OneWay}" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Run Text=" productos"/>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="PaginaAnteriorBtn" Content="Anterior"
                            Height="34" Padding="14,0" FontSize="12"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Click="PaginaAnterior_Click"/>
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="14,0" Height="34">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12">
                            <Run Text="{Binding PaginaActual, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text=" / " Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Run Text="{Binding TotalPaginas, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                    <Button x:Name="PaginaSiguienteBtn" Content="Siguiente"
                            Height="34" Padding="14,0" FontSize="12"
                            Style="{StaticResource PrimaryButton}" Margin="6,0,0,0"
                            Click="PaginaSiguiente_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- SIDEBAR DETALLE -->
        <Border Grid.Column="1"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding ProductoSeleccionado, Converter={StaticResource NullToVisibility}}">
            <Grid Width="300">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="22,20">
                    <StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="DETALLE DE PRODUCTO" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ProductoSeleccionado.Nombre, Mode=OneWay}"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="CerrarDetalleBtn"
                                    Content="X" Width="28" Height="28" FontSize="12"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Cursor="Hand" VerticalAlignment="Top"
                                    Click="CerrarDetalle_Click"/>
                        </Grid>

                        <Border CornerRadius="6" Padding="12,6"
                                Margin="0,0,0,16" HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProductoSeleccionado.Activo}" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="ACTIVO"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProductoSeleccionado.Activo}" Value="False">
                                                <Setter Property="Text" Value="INACTIVO"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="CATEGORIA" Style="{StaticResource SideLabel}"/>
                        <TextBlock Text="{Binding ProductoSeleccionado.CategoriaNombre, Mode=OneWay}"
                                   Style="{StaticResource SideValue}"/>

                        <TextBlock Text="CODIGO DE BARRAS" Style="{StaticResource SideLabel}"/>
                        <TextBlock Text="{Binding ProductoSeleccionado.CodigoBarra, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="15"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="UNIDAD DE MEDIDA" Style="{StaticResource SideLabel}"/>
                        <TextBlock Text="{Binding ProductoSeleccionado.UnidadMedida, Mode=OneWay}"
                                   Style="{StaticResource SideValue}"/>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="10" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Precio Venta"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding ProductoSeleccionado.PrecioVentaActual, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Precio Costo"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding ProductoSeleccionado.PrecioCostoActual, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>
                                <Separator Background="{DynamicResource BorderBrush}" Margin="0,4,0,10"/>
                                <Grid>
                                    <TextBlock Text="Stock actual"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding ProductoSeleccionado.StockActual, Mode=OneWay}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button x:Name="EditarProductoBtn"
                                Content="Editar producto"
                                Height="40" FontSize="13"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,8"
                                Click="EditarProducto_Click"/>

                        <Button x:Name="VerMovimientosBtn"
                                Content="Ver movimientos"
                                Height="40" FontSize="13"
                                Style="{StaticResource GhostBtn}"
                                Margin="0,0,0,8"
                                Click="VerMovimientos_Click"/>

                        <Button x:Name="DesactivarProductoBtn"
                                Content="Desactivar"
                                Height="40" FontSize="13"
                                Background="Transparent"
                                Foreground="{DynamicResource ErrorBrush}"
                                BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" Cursor="Hand"
                                Click="DesactivarProducto_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource ErrorAlphaBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

<!-- POPUP: Ajuste Masivo de Precios -->
        <Border Grid.Row="0" Grid.RowSpan="10"
                Background="#CC000000"
                Visibility="{Binding MostrarPopupAjuste, Converter={StaticResource BoolToVisibility}}">
            <Border Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Width="900"
                    MaxHeight="700"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="12,12,0,0" Padding="24,16">
                        <StackPanel>
                            <TextBlock Text="⚡ Ajuste Masivo de Precios" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Seleccioná el tipo de ajuste y el valor para pré-actualizar los precios de tus productos"
                                   FontSize="12" Foreground="#BFFFFFFF" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Opciones -->
                    <Grid Grid.Row="1" Margin="24,20,24,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tipo -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo de Ajuste:"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                            <RadioButton x:Name="TipoPorcentaje" Content="Porcentaje (%)" GroupName="TipoAjuste"
                                       IsChecked="True" Foreground="White" Margin="0,0,20,0"/>
                            <RadioButton x:Name="TipoFijo" Content="Monto Fijo ($)" GroupName="TipoAjuste"
                                       Foreground="White"/>
                        </StackPanel>

                        <!-- Valor -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Valor (% o $):"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                            <TextBox x:Name="PorcentajeInput"
                                     Text="{Binding PorcentajeAjuste, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" Height="36" FontSize="14"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="White"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1" Padding="10,0"/>
                            <TextBlock x:Name="SignoLabel" Text="%" FontSize="14"
                                       VerticalAlignment="Center" Margin="8,0,24,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox x:Name="MontoFijoInput"
                                     Text="{Binding MontoFijo, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" Height="36" FontSize="14"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="White"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1" Padding="10,0"
                                     Visibility="Collapsed"/>
                            <TextBlock x:Name="SignoPesos" Text="$" FontSize="14"
                                       VerticalAlignment="Center" Margin="8,0,24,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="Collapsed"/>
                            <CheckBox x:Name="AplicarVentaCheck" Content="Precio Venta"
                                     IsChecked="{Binding AplicarAPrecioVenta}"
                                     Foreground="White" VerticalAlignment="Center"/>
                            <CheckBox x:Name="AplicarCostoCheck" Content="Precio Costo"
                                     IsChecked="{Binding AplicarAPrecioCosto}"
                                     Foreground="White" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>

                        <!-- Botón -->
                        <Button Grid.Row="4" Grid.Column="1" x:Name="GenerarPreviewBtn"
                                Content="Vista Previa" Height="36" Padding="20,0"
                                HorizontalAlignment="Left" Margin="16,8,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="GenerarPreview_Click"/>
                    </Grid>

                    <!-- Preview Table -->
                    <Border Grid.Row="2" Margin="24,0,24,20"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <DataGrid ItemsSource="{Binding ProductosPreview}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#08FFFFFF"
                                  Foreground="White"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Precio Venta" Binding="{Binding PrecioVentaActual, StringFormat=C0}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Nuevo Venta" Binding="{Binding PrecioVentaNuevo, StringFormat=C0}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Var %" Binding="{Binding VariacionPorcentaje}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Footer -->
                    <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="0,0,12,12" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ProductosActualizados, StringFormat='{}{0} productos a actualizar'}"
                                       FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="CancelarAjusteBtn" Content="Cancelar"
                                        Height="40" Padding="24,0"
                                        Background="{DynamicResource CardBrush}"
                                        Foreground="White"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Click="CancelarAjuste_Click"/>
                                <Button x:Name="ConfirmarAjusteBtn" Content="Confirmar Cambios"
                                        Height="40" Padding="24,0" Margin="12,0,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="ConfirmarAjuste_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
</Border>
        </Border>

    </Grid>
</UserControl>
