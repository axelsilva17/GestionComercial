<UserControl x:Class="GestionComercial.UI.Views.Reportes.ReporteGerenciaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,16"/>
        </Style>
        <Style x:Key="CardNoPad" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <Style x:Key="BtnLink" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,28">

            <!-- ── Row 1: KPIs ─────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" BorderBrush="{DynamicResource SuccessBrush}">
                    <StackPanel>
                        <TextBlock Text="VENTAS ACUMULADAS" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding VentasAcumuladas, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="últimos 6 meses" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="COMPRAS ACUMULADAS" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ComprasAcumuladas, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"/>
                        <TextBlock Text="últimos 6 meses" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}" BorderBrush="{DynamicResource PrimaryBrush}">
                    <StackPanel>
                        <TextBlock Text="RESULTADO NETO" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ResultadoAcumulado, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="ventas menos compras" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="MARGEN PROMEDIO" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding MargenPromedio, StringFormat='{}{0:N1}%'}"
                                   FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0">
                            <Run Text="{Binding ClientesNuevos, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Run Text=" clientes nuevos"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Row 2: Gráfico barras + tabla mensual ───────────────────── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Barras Ventas vs Compras -->
                <Border Grid.Column="0" Style="{StaticResource CardNoPad}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="20,16,20,10">
                            <StackPanel>
                                <TextBlock Text="VENTAS VS COMPRAS POR MES" Style="{StaticResource ColHeader}"/>
                                <TextBlock Text="Comparativa mensual" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Button Style="{StaticResource BtnLink}" Content="Actualizar"
                                    HorizontalAlignment="Right" x:Name="Actualizar"/>
                        </Grid>
                        <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                            Series="{Binding SeriesBarras}"
                                            XAxes="{Binding EjeXBarras}"
                                            YAxes="{Binding EjeY}"
                                            Background="Transparent"
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

                <!-- Tabla mensual compacta -->
                <Border Grid.Column="2" Style="{StaticResource CardNoPad}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,10">
                            <TextBlock Text="DETALLE MENSUAL" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Resultado y margen" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding VentasMensuales}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  GridLinesVisibility="None" HeadersVisibility="Column"
                                  Background="Transparent" BorderThickness="0"
                                  RowHeight="38" ColumnHeaderHeight="30" Margin="8,0,8,8"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="MES" Binding="{Binding Mes}" Width="80"/>
                                <DataGridTemplateColumn Header="VENTAS" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Ventas, Converter={StaticResource DecimalToMoneda}}"
                                                       Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="MARGEN" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="5"
                                                    Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Margen, StringFormat='{}{0:N1}%'}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="{DynamicResource SuccessBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Row 3: Línea evolución + Torta métodos de pago ─────────── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Línea evolución ventas -->
                <Border Grid.Column="0" Style="{StaticResource CardNoPad}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,10">
                            <TextBlock Text="EVOLUCIÓN DE VENTAS" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Tendencia últimos 6 meses" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                            Series="{Binding SeriesLinea}"
                                            XAxes="{Binding EjeXLinea}"
                                            YAxes="{Binding EjeY}"
                                            Background="Transparent"
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

                <!-- Torta métodos de pago -->
                <Border Grid.Column="2" Style="{StaticResource CardNoPad}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,10">
                            <TextBlock Text="DISTRIBUCIÓN MÉTODOS DE PAGO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Proporción por tipo" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <lvc:PieChart Grid.Row="1" Margin="12,0,12,12"
                                      Series="{Binding SeriesTorta}"
                                      Background="Transparent"
                                      TooltipPosition="Top"
                                      LegendPosition="Right"
                                      LegendTextPaint="{x:Null}"/>
                    </Grid>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
