<UserControl x:Class="GestionComercial.UI.Views.Reportes.ReporteGerenciaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,16"/>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- KPIs resumen ejecutivo -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}"
                        BorderBrush="{DynamicResource SuccessBrush}">
                    <StackPanel>
                        <TextBlock Text="VENTAS ACUMULADAS" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding VentasAcumuladas, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="26" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="ultimos 6 meses" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="COMPRAS ACUMULADAS" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ComprasAcumuladas, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="26" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"/>
                        <TextBlock Text="ultimos 6 meses" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}"
                        BorderBrush="{DynamicResource PrimaryBrush}">
                    <StackPanel>
                        <TextBlock Text="RESULTADO NETO" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ResultadoAcumulado, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="26" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="ventas menos compras" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="MARGEN PROMEDIO" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding MargenPromedio, StringFormat='{}{0:N1}%'}"
                                   FontSize="26" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0">
                            <Run Text="{Binding ClientesNuevos, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Run Text=" clientes nuevos"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Ventas vs Compras por mes -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="20,16,20,12">
                        <StackPanel>
                            <TextBlock Text="VENTAS VS COMPRAS POR MES" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Resultado neto y margen mensual" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Button Content="Actualizar" HorizontalAlignment="Right"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource PrimaryBrush}" FontSize="12" Cursor="Hand"
                                Click="Actualizar_Click"/>
                    </Grid>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding VentasMensuales}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              GridLinesVisibility="None" HeadersVisibility="Column"
                              Background="Transparent" BorderThickness="0"
                              RowHeight="44" ColumnHeaderHeight="34" Margin="8,0,8,8"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MES"       Binding="{Binding Mes}"      Width="80"/>
                            <DataGridTemplateColumn Header="VENTAS" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Ventas, Converter={StaticResource DecimalToMoneda}}"
                                                   Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="COMPRAS" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Compras, Converter={StaticResource DecimalToMoneda}}"
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   VerticalAlignment="Center" Margin="12,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="RESULTADO" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Resultado, Converter={StaticResource DecimalToMoneda}}"
                                                   Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="12,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="MARGEN" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                                Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Margen, StringFormat='{}{0:N1}%'}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{DynamicResource SuccessBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Top Productos + Vendedores -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top productos -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,12">
                            <TextBlock Text="TOP 5 PRODUCTOS" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Por ingresos generados" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding TopProductos}" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Nombre}" FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                    <Run Text="{Binding Cantidad, Mode=OneWay}"/>
                                                    <Run Text=" vendidos"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Ingresos, Converter={StaticResource DecimalToMoneda}}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                                                    CornerRadius="6" Padding="8,3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Margen, StringFormat='{}{0:N1}%'}"
                                                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Rendimiento vendedores -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,12">
                            <TextBlock Text="RENDIMIENTO DE VENDEDORES" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Ventas, totales y ticket promedio" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Vendedores}" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,12" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="36" Height="36" CornerRadius="8"
                                                    Background="{DynamicResource SurfaceBrush}" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Nombre[0]}" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Nombre}" FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                    <Run Text="{Binding Ventas, Mode=OneWay}"/>
                                                    <Run Text=" ventas · ticket prom "/>
                                                    <Run Text="{Binding TicketProm, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                       FontSize="15" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
