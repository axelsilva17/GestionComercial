<UserControl x:Class="GestionComercial.UI.Views.Reportes.ReporteAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:cal="http://www.caliburnproject.org"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:DecimalToMonedaConverter x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
        <Style x:Key="CardNoPad" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FiltroBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Main Grid: holds ScrollViewer (content) + SidePanel overlay -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ── MAIN CONTENT: ScrollViewer ───────────────────────────────────── -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,28">

                <!-- Barra de filtros -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="PERÍODO" Style="{StaticResource ColHeader}"
                                   VerticalAlignment="Center" Margin="0"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Desde" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding FechaDesde, Mode=TwoWay}"
                                        Style="{StaticResource FilterDatePickerStyle}" Width="130"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Hasta" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding FechaHasta, Mode=TwoWay}"
                                        Style="{StaticResource FilterDatePickerStyle}" Width="130"/>
                        </StackPanel>

                        <Button Grid.Column="6" Style="{StaticResource FiltroBtn}" Content="Este mes" cal:Message.Attach="FiltrarEsteMes"/>
                        <Button Grid.Column="8" Style="{StaticResource FiltroBtn}" Content="3 meses" cal:Message.Attach="FiltrarUltimos3"/>
                        <Button Grid.Column="10" Style="{StaticResource FiltroBtn}" Content="6 meses" cal:Message.Attach="FiltrarUltimos6"/>
                        <Button Grid.Column="12" Style="{StaticResource FiltroBtn}" Content="Este año" cal:Message.Attach="FiltrarEsteAnio"/>

                        <Button Grid.Column="14" cal:Message.Attach="Actualizar"
                                Content="▶  Aplicar"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="#0F172A" FontWeight="Bold" FontSize="12"
                                Padding="18,6" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <CheckBox Grid.Column="15" 
                                  IsChecked="{Binding AbrirDespuesDeExportar, Mode=TwoWay}"
                                  Content="Auto-abrir"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="11"
                                  VerticalAlignment="Center"/>

                        <!-- Botón Exportar Caja Auditoría -->
                        <Button Grid.Column="16" cal:Message.Attach="ExportarCajaAuditoriaExcel"
                                Content="📦 Exp. Caja"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" FontWeight="SemiBold" FontSize="11"
                                Padding="10,6" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Botón Exportar Todo Completo -->
                        <Button Grid.Column="18" cal:Message.Attach="ExportarExcel"
                                Content="📊 Informe"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" FontSize="11"
                                Padding="12,6" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Botón Turnos -->
                        <Button Grid.Column="20" cal:Message.Attach="MostrarTurnos" 
                                Content="Turnos" Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                FontWeight="SemiBold" FontSize="11" Padding="10,6" Cursor="Hand" />
                        <!-- Botón Caja Auditoría (navegación) -->
                        <Button Grid.Column="22" cal:Message.Attach="MostrarAuditoria" 
                                Content="Caja Auditoría" Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                FontWeight="SemiBold" FontSize="11" Padding="10,6" Cursor="Hand" />
                    </Grid>
                </Border>

                <!-- KPIs -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="VENTAS DEL PERÍODO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding CantidadVentasMes}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="transacciones" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="STOCK CRÍTICO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding ProductosStockCritico}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource ErrorBrush}"/>
                            <TextBlock Text="productos" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="COMPRAS DEL PERÍODO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding ComprasDelMes}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}"/>
                            <TextBlock Text="órdenes emitidas" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="CLIENTES NUEVOS" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding ClientesNuevos}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text="este mes" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="8" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="VENTAS PENDIENTES" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding VentasPendientes}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}"/>
                            <TextBlock Text="por cobrar" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Línea ventas por día -->
                <Border Style="{StaticResource CardNoPad}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,10">
                            <TextBlock Text="STOCK ACTUAL VS MÍNIMO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Productos con reposición urgente" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                            Series="{Binding SeriesVentasDia}"
                                            XAxes="{Binding EjeXVentasDia}"
                                            YAxes="{Binding EjeYEntero}"
                                            Background="Transparent"
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

                <!-- Gráficos: Métodos de Pago + Top Productos -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Gráfico: Métodos de Pago (dona) -->
                    <Border Grid.Column="0" Style="{StaticResource CardNoPad}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="20,16,20,10">
                                <TextBlock Text="MÉTODOS DE PAGO" Style="{StaticResource ColHeader}"/>
                                <TextBlock Text="Distribución del período" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <lvc:PieChart Grid.Row="1" Margin="12,0,12,12"
                                          Series="{Binding SeriesMetodosPago}"
                                          Background="Transparent"
                                          InitialRotation="-90"/>
                        </Grid>
                    </Border>

                    <!-- Gráfico: Top Productos -->
                    <Border Grid.Column="2" Style="{StaticResource CardNoPad}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="20,16,20,10">
                                <TextBlock Text="TOP PRODUCTOS" Style="{StaticResource ColHeader}"/>
                                <TextBlock Text="Más vendidos del período" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                                Series="{Binding SeriesTopProductos}"
                                                XAxes="{Binding EjeXTopProductos}"
                                                YAxes="{Binding EjeYEntero}"
                                                Background="Transparent"
                                                TooltipPosition="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Stock crítico + Compras recientes -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Stock crítico -->
                    <Border Grid.Column="0" Style="{StaticResource CardNoPad}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="16,14,16,10">
                                    <TextBlock Text="STOCK CRÍTICO" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="Requieren reposición" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding StockCritico}" Margin="8,0,8,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,8" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Nombre}" FontSize="12" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                            <Run Text="Mínimo: "/>
                                                            <Run Text="{Binding StockMinimo, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="6" Padding="10,4"
                                                            MinWidth="48" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding StockActual}" FontSize="14" FontWeight="Bold"
                                                                       Foreground="White" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Estado}" FontSize="9" Foreground="White"
                                                                       HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                    <!-- Compras recientes -->
                    <Border Grid.Column="2" Style="{StaticResource CardNoPad}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="16,14,16,10">
                                    <TextBlock Text="COMPRAS RECIENTES" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="Últimas órdenes" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding ComprasRecientes}" Margin="8,0,8,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,10" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Proveedor}" FontSize="12" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Fecha}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                </Grid>



            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
