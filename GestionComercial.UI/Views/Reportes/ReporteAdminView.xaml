<UserControl x:Class="GestionComercial.UI.Views.Reportes.ReporteAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:cal="http://www.caliburnproject.org"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:DecimalToMonedaConverter x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
        <Style x:Key="CardNoPad" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FiltroBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Main Grid: holds ScrollViewer (content) + SidePanel overlay -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ── MAIN CONTENT: ScrollViewer ───────────────────────────────────── -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,28">

                <!-- Barra de filtros -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="PERÍODO" Style="{StaticResource ColHeader}"
                                   VerticalAlignment="Center" Margin="0"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Desde" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding FechaDesde, Mode=TwoWay}"
                                        FontSize="12" Width="130"
                                        Background="{DynamicResource SurfaceBrush}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Hasta" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding FechaHasta, Mode=TwoWay}"
                                        FontSize="12" Width="130"
                                        Background="{DynamicResource SurfaceBrush}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <Button Grid.Column="6" Style="{StaticResource FiltroBtn}" Content="Este mes" cal:Message.Attach="FiltrarEsteMes"/>
                        <Button Grid.Column="8" Style="{StaticResource FiltroBtn}" Content="3 meses" cal:Message.Attach="FiltrarUltimos3"/>
                        <Button Grid.Column="10" Style="{StaticResource FiltroBtn}" Content="6 meses" cal:Message.Attach="FiltrarUltimos6"/>
                        <Button Grid.Column="12" Style="{StaticResource FiltroBtn}" Content="Este año" cal:Message.Attach="FiltrarEsteAnio"/>

                        <Button Grid.Column="14" cal:Message.Attach="Actualizar"
                                Content="▶  Aplicar"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="#0F172A" FontWeight="Bold" FontSize="12"
                                Padding="18,6" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="15" cal:Message.Attach="MostrarAuditoria"
                                Content="📋  Auditoría"
                                Background="{DynamicResource SurfaceBrush}"
                                Foreground="{DynamicResource PrimaryBrush}"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                BorderThickness="1" FontWeight="SemiBold" FontSize="12"
                                Padding="14,6" Cursor="Hand" Margin="8,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- KPIs -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="VENTAS DEL PERÍODO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding CantidadVentasMes}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="transacciones" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="STOCK CRÍTICO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding ProductosStockCritico}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource ErrorBrush}"/>
                            <TextBlock Text="productos" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="COMPRAS DEL PERÍODO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding ComprasDelMes}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}"/>
                            <TextBlock Text="órdenes emitidas" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="CLIENTES NUEVOS" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding ClientesNuevos}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text="este mes" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="8" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="VENTAS PENDIENTES" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="{Binding VentasPendientes}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}"/>
                            <TextBlock Text="por cobrar" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Línea ventas por día -->
                <Border Style="{StaticResource CardNoPad}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,10">
                            <TextBlock Text="VENTAS DEL PERÍODO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Actividad acumulada" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                            Series="{Binding SeriesVentasDia}"
                                            XAxes="{Binding EjeXVentasDia}"
                                            YAxes="{Binding EjeYMoneda}"
                                            Background="Transparent"
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

                <!-- Stock vs Mínimo + listas -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardNoPad}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="230"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="20,16,20,10">
                                <TextBlock Text="STOCK ACTUAL VS MÍNIMO" Style="{StaticResource ColHeader}"/>
                                <TextBlock Text="Productos con reposición urgente" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                                Series="{Binding SeriesStock}"
                                                XAxes="{Binding EjeXStock}"
                                                YAxes="{Binding EjeYEntero}"
                                                Background="Transparent"
                                                TooltipPosition="Top"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <!-- Stock crítico -->
                        <Border Style="{StaticResource CardNoPad}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="16,14,16,10">
                                    <TextBlock Text="STOCK CRÍTICO" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="Requieren reposición" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding StockCritico}" Margin="8,0,8,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,8" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Nombre}" FontSize="12" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                            <Run Text="Mínimo: "/>
                                                            <Run Text="{Binding StockMinimo, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="6" Padding="10,4"
                                                            MinWidth="48" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding StockActual}" FontSize="14" FontWeight="Bold"
                                                                       Foreground="White" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Estado}" FontSize="9" Foreground="White"
                                                                       HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <!-- Compras recientes -->
                        <Border Style="{StaticResource CardNoPad}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="16,14,16,10">
                                    <TextBlock Text="COMPRAS RECIENTES" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="Últimas órdenes" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding ComprasRecientes}" Margin="8,0,8,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,10" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Proveedor}" FontSize="12" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Fecha}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>



            </StackPanel>
        </ScrollViewer>

        <!-- ── FULL-WIDTH OVERLAY PANEL (90% screen width) ─────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Semi-transparent backdrop (click to close) -->
            <Border x:Name="OverlayBackdrop" Grid.Column="0"
                    Background="#80000000"
                    MouseLeftButtonDown="OverlayBackdrop_MouseLeftButtonDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding MostrarPanelAuditoria}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Full-Width Panel (90% width) -->
            <Border x:Name="AuditoriaSidePanel" Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    ClipToBounds="True"
                    HorizontalAlignment="Stretch"
                    Visibility="{Binding MostrarPanelAuditoria, Converter={StaticResource BoolToVisibility}}">
                
                <!-- Panel Content -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Background="{DynamicResource SurfaceBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="30,20,30,16">
                            <TextBlock Text="AUDITORÍA DETALLADA" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Seguimiento completo de cajas y movimientos" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" cal:Message.Attach="OcultarAuditoria"
                                ToolTip="Cerrar panel"
                                Background="Transparent"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                BorderThickness="0" FontSize="16"
                                Width="36" Height="36" Cursor="Hand" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="✕"/>
                        </Button>
                    </Grid>

                    <!-- Date Filters -->
                    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="30,0,30,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Desde" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker SelectedDate="{Binding FechaDesde, Mode=TwoWay}"
                                            FontSize="12" Width="140"
                                            Background="{DynamicResource BackgroundBrush}"
                                            Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Hasta" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker SelectedDate="{Binding FechaHasta, Mode=TwoWay}"
                                            FontSize="12" Width="140"
                                            Background="{DynamicResource BackgroundBrush}"
                                            Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="6" cal:Message.Attach="CargarAuditoria"
                                    Content="🔍" FontSize="14"
                                    ToolTip="Aplicar filtro"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Foreground="#0F172A" FontWeight="Bold"
                                    Width="36" Height="32" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- KPIs de Caja (integrados en panel de auditoría) -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="30,16,30,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- CAJAS DEL PERÍODO -->
                            <Border Grid.Column="0" Style="{StaticResource Card}" 
                                    BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="0,0,0,3">
                                <StackPanel>
                                    <TextBlock Text="CAJAS DEL PERÍODO" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="{Binding TotalCajas}" FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}"/>
                                    <TextBlock Text="registradas" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- CON DIFERENCIA -->
                            <Border Grid.Column="2" Style="{StaticResource Card}"
                                    BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="0,0,0,3">
                                <StackPanel>
                                    <TextBlock Text="CON DIFERENCIA" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="{Binding CajasConDiferencia}" FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource ErrorBrush}"/>
                                    <TextBlock Text="revisar" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- INGRESOS -->
                            <Border Grid.Column="4" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="INGRESOS" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="{Binding TotalIngresos, Converter={StaticResource DecimalToMoneda}}"
                                               FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                    <TextBlock Text="total en período" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- EGRESOS -->
                            <Border Grid.Column="6" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="EGRESOS" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Text="{Binding TotalEgresos, Converter={StaticResource DecimalToMoneda}}"
                                               FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"/>
                                    <TextBlock Text="total en período" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Tabs Content -->
                    <TabControl Grid.Row="3" Background="Transparent" BorderThickness="0" Margin="24,16,24,24">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Padding" Value="18,10"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                                    Padding="{TemplateBinding Padding}" Cursor="Hand">
                                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- Tab 1: Auditoría de Cajas -->
                        <TabItem Header="Auditoría Cajas">
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Section Label -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,0,8,12">
                                    <Border Width="4" Height="20" CornerRadius="2" Background="{DynamicResource PrimaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="AUDITORÍA DE CAJAS" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding AuditoriaCajas.Count, StringFormat=' ({0} registros)'}"
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="8,0,8,12"/>

                                <!-- DataGrid with proper alignment -->
                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding AuditoriaCajas}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          GridLinesVisibility="None" HeadersVisibility="Column"
                                          Background="Transparent" BorderThickness="0"
                                          RowBackground="Transparent" AlternatingRowBackground="#10FFFFFF"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          FontSize="12" RowHeight="44" ColumnHeaderHeight="40"
                                          Margin="8,0,8,8">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A3A5C"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A3A5C"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Padding" Value="12,10"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="FECHA" Binding="{Binding FechaOperacion, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="130"/>
                                        <DataGridTextColumn Header="USUARIO" Binding="{Binding Usuario}" Width="*"/>
                                        <DataGridTextColumn Header="OPERACIÓN" Binding="{Binding TipoOperacion}" Width="110"/>
                                        <DataGridTextColumn Header="TABLA" Binding="{Binding NombreTabla}" Width="110"/>
                                        <DataGridTextColumn Header="REGISTRO" Binding="{Binding RegistroId}" Width="80"/>
                                        <DataGridTextColumn Header="CAMBIOS" Binding="{Binding DetalleCambios}" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- Tab 2: Movimientos de Caja -->
                        <TabItem Header="Movimientos Caja">
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Section Label -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,0,8,12">
                                    <Border Width="4" Height="20" CornerRadius="2" Background="{DynamicResource WarningBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="MOVIMIENTOS DE CAJA" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding AuditoriaMovimientos.Count, StringFormat=' ({0} registros)'}"
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}" Margin="8,0,8,12"/>

                                <!-- DataGrid with proper alignment -->
                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding AuditoriaMovimientos}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          GridLinesVisibility="None" HeadersVisibility="Column"
                                          Background="Transparent" BorderThickness="0"
                                          RowBackground="Transparent" AlternatingRowBackground="#10FFFFFF"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          FontSize="12" RowHeight="44" ColumnHeaderHeight="40"
                                          Margin="8,0,8,8">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A3A5C"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#1A3A5C"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Padding" Value="12,10"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="FECHA" Binding="{Binding FechaOperacion, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="130"/>
                                        <DataGridTextColumn Header="USUARIO" Binding="{Binding Usuario}" Width="*"/>
                                        <DataGridTextColumn Header="OPERACIÓN" Binding="{Binding TipoOperacion}" Width="110"/>
                                        <DataGridTextColumn Header="TABLA" Binding="{Binding NombreTabla}" Width="110"/>
                                        <DataGridTextColumn Header="REGISTRO" Binding="{Binding RegistroId}" Width="80"/>
                                        <DataGridTextColumn Header="CAMBIOS" Binding="{Binding DetalleCambios}" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
