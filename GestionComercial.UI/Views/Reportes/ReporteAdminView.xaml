<UserControl x:Class="GestionComercial.UI.Views.Reportes.ReporteAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,16"/>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- KPIs operativos (sin financieros) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="VENTAS DEL MES" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding CantidadVentasMes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="transacciones" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="STOCK CRITICO" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ProductosStockCritico}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                        <TextBlock Text="productos" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="COMPRAS DEL MES" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ComprasDelMes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="ordenes emitidas" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CLIENTES NUEVOS" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ClientesNuevos}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="este mes" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="8" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="VENTAS PENDIENTES" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding VentasPendientes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="por cobrar" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Stock critico + Compras recientes -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stock critico -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="20,16,20,12">
                            <StackPanel>
                                <TextBlock Text="PRODUCTOS CON STOCK CRITICO" Style="{StaticResource ColHeader}"/>
                                <TextBlock Text="Requieren reposicion urgente" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Button Content="Actualizar" HorizontalAlignment="Right"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryBrush}" FontSize="12" Cursor="Hand"
                                    Click="Actualizar_Click"/>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding StockCritico}" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Nombre}" FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                    <Run Text="Minimo: "/>
                                                    <Run Text="{Binding StockMinimo, Mode=OneWay}"/>
                                                    <Run Text=" unidades"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="8" Padding="12,5"
                                                    MinWidth="56" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding StockActual}" FontSize="16" FontWeight="Bold"
                                                               Foreground="White" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Estado}" FontSize="9" Foreground="White"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Compras recientes -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,12">
                            <TextBlock Text="COMPRAS RECIENTES" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Ultimas ordenes emitidas" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ComprasRecientes}" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,12" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Proveedor}" FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                    <Run Text="{Binding Fecha, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding Productos, Mode=OneWay}"/>
                                                    <Run Text=" productos"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
