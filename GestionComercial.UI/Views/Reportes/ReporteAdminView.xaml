<UserControl x:Class="GestionComercial.UI.Views.Reportes.ReporteAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="20,16"/>
        </Style>
        <Style x:Key="CardNoPad" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <Style x:Key="BtnLink" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,28">

            <!-- ── Row 1: KPIs operativos ──────────────────────────────────── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="VENTAS DEL MES" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding CantidadVentasMes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="transacciones" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="STOCK CRÍTICO" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ProductosStockCritico}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                        <TextBlock Text="productos" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="COMPRAS DEL MES" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ComprasDelMes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="órdenes emitidas" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CLIENTES NUEVOS" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding ClientesNuevos}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="este mes" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="8" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="VENTAS PENDIENTES" Style="{StaticResource ColHeader}"/>
                        <TextBlock Text="{Binding VentasPendientes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="por cobrar" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Row 2: Gráfico ventas por día ───────────────────────────── -->
            <Border Style="{StaticResource CardNoPad}" Margin="0,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="20,16,20,10">
                        <StackPanel>
                            <TextBlock Text="VENTAS DEL MES POR DÍA" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Actividad diaria acumulada" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Button Style="{StaticResource BtnLink}" Content="Actualizar"
                                HorizontalAlignment="Right" x:Name="Actualizar"/>
                    </Grid>
                    <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                        Series="{Binding SeriesVentasDia}"
                                        XAxes="{Binding EjeXVentasDia}"
                                        YAxes="{Binding EjeYMoneda}"
                                        Background="Transparent"
                                        TooltipPosition="Top"/>
                </Grid>
            </Border>

            <!-- ── Row 3: Stock actual vs mínimo + listas ──────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Gráfico stock actual vs mínimo -->
                <Border Grid.Column="0" Style="{StaticResource CardNoPad}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="20,16,20,10">
                            <TextBlock Text="STOCK ACTUAL VS MÍNIMO" Style="{StaticResource ColHeader}"/>
                            <TextBlock Text="Productos con reposición urgente" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Margin="12,0,12,12"
                                            Series="{Binding SeriesStock}"
                                            XAxes="{Binding EjeXStock}"
                                            YAxes="{Binding EjeYEntero}"
                                            Background="Transparent"
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

                <!-- Lista stock crítico + compras recientes (columna derecha) -->
                <StackPanel Grid.Column="2">
                    <!-- Stock crítico -->
                    <Border Style="{StaticResource CardNoPad}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="16,14,16,10">
                                <TextBlock Text="STOCK CRÍTICO" Style="{StaticResource ColHeader}"/>
                                <TextBlock Text="Requieren reposición" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding StockCritico}" Margin="8,0,8,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="10,8" Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nombre}" FontSize="12" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                        <Run Text="Mínimo: "/>
                                                        <Run Text="{Binding StockMinimo, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="6" Padding="10,4"
                                                        MinWidth="48" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding StockActual}" FontSize="14" FontWeight="Bold"
                                                                   Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Estado}" FontSize="9" Foreground="White"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Compras recientes -->
                    <Border Style="{StaticResource CardNoPad}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="16,14,16,10">
                                <TextBlock Text="COMPRAS RECIENTES" Style="{StaticResource ColHeader}"/>
                                <TextBlock Text="Últimas órdenes" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ComprasRecientes}" Margin="8,0,8,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="10,10" Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Proveedor}" FontSize="12" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                        <Run Text="{Binding Fecha, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Total, Converter={StaticResource DecimalToMoneda}}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
