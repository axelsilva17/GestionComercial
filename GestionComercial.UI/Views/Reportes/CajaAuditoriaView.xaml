<UserControl x:Class="GestionComercial.UI.Views.Reportes.CajaAuditoriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <converters:DecimalToMonedaConverter x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding Titulo}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="{Binding Subtitulo}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            <!-- Apertura Caja: selection of Caja and Turno to open -->
            <GroupBox Header="Apertura Caja" Margin="0,12,0,0" Padding="10">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0" Spacing="10">
                <ComboBox Width="180" ItemsSource="{Binding AvailableCajas}" DisplayMemberPath="Nombre" SelectedItem="{Binding SelectedCaja}" />
                <ComboBox Width="180" ItemsSource="{Binding AvailableTurnos}" DisplayMemberPath="Nombre" SelectedItem="{Binding SelectedTurno}" />
                <Button Content="Abrir Caja" Command="{Binding OpenCajaCommand}" Width="120" />
              </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Filtros y KPIs -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Fechas -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <DatePicker SelectedDate="{Binding FechaDesde}" Width="130" Margin="0,0,8,0"/>
                <TextBlock Text="—" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FechaHasta}" Width="130"/>
            </StackPanel>

            <!-- KPIs -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="Total Cajas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalCajas}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="Cerradas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding CajasCerradas}" FontSize="24" FontWeight="Bold" Foreground="#10B981"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="Con Diferencia" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding CajasConDiferencia}" FontSize="24" FontWeight="Bold" Foreground="#F59E0B"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="Total Diferencia" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalDiferencias, Converter={StaticResource DecimalToMoneda}}" 
                                   FontSize="24" FontWeight="Bold" Foreground="#EF4444"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Export -->
            <Button Grid.Column="3" Content="Exportar Excel" cal:Message.Attach="ExportarExcel"
                    Padding="16,8" Margin="12,0,0,0" Background="{DynamicResource PrimaryBrush}"
                    Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <!-- Contenido principal: Cajas + Movimientos -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de cajas -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Cajas" FontSize="16" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Cajas}" SelectedItem="{Binding CajaSeleccionada}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              Background="Transparent" BorderThickness="0" GridLinesVisibility="None"
                              RowBackground="Transparent" AlternatingRowBackground="#0AFFFFFF"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaApertura}" Width="90"/>
                            <DataGridTextColumn Header="Hora" Binding="{Binding HoraApertura}" Width="60"/>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding UsuarioApertura}" Width="100"/>
                            <DataGridTextColumn Header="Inicial" Binding="{Binding MontoInicial, Converter={StaticResource DecimalToMoneda}}" Width="90"/>
                            <DataGridTextColumn Header="Efectivo" Binding="{Binding VentasEfectivo, Converter={StaticResource DecimalToMoneda}}" Width="90"/>
                            <DataGridTextColumn Header="Final" Binding="{Binding MontoFinal, Converter={StaticResource DecimalToMoneda}}" Width="90"/>
                            <DataGridTextColumn Header="Diff" Binding="{Binding DiferenciaConEfectivo, Converter={StaticResource DecimalToMoneda}}" Width="80"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Detalle de movimientos -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Movimientos" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CajaSeleccionada.FechaApertura, StringFormat='Caja del {0}'}" 
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Movimientos}" BorderThickness="0" 
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                                        Padding="12,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icono}" FontSize="16" 
                                                   Foreground="{Binding EsIngreso, Converter={StaticResource BoolToColor}}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding TipoOperacion}" FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Descripcion}" FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Fecha}" FontSize="10" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Monto, Converter={StaticResource DecimalToMoneda}}"
                                                   FontWeight="Bold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
