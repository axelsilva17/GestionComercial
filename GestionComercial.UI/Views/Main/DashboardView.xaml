<UserControl x:Class="GestionComercial.UI.Views.Main.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:DecimalToMonedaConverter   x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>

        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Padding"         Value="22,18"/>
        </Style>

        <Style x:Key="SubCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="18,14"/>
        </Style>

        <Style x:Key="QuickAction" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"  Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Saludo -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>  <!-- KPIs según rol -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Fila finanzas Gerente -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Fila operaciones Admin -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Acciones rápidas -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Actividad + stock/caja -->
            </Grid.RowDefinitions>

            <!-- ══ SALUDO ════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="14" Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Buen día, "/>
                            <Run Text="{Binding UsuarioNombre, Mode=OneWay}"
                                 Foreground="{DynamicResource PrimaryBrush}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding UsuarioRol, Mode=OneWay}"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                            <TextBlock Text="{Binding FechaHoy, Mode=OneWay}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TituloSaludo, Mode=OneWay}"
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ KPIs — GERENTE ════════════════════════════════════════════ -->
            <Grid Grid.Row="2"
                  Visibility="{Binding MostrarSeccionGerente, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource SuccessAlphaBrush}">
                                <TextBlock Text="$" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="VENTAS DEL MES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalVentasMes, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <Border CornerRadius="6" Padding="8,3" Margin="0,6,0,0" HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SuccessAlphaBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CrecimientoPositivo}" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource ErrorAlphaBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="11" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CrecimientoPositivo}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding CrecimientoMes, StringFormat='{}{0:+0.0;-0.0}%', Mode=OneWay}"/>
                                <Run Text=" vs mes anterior"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource ErrorAlphaBrush}">
                                <TextBlock Text="🛒" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="COMPRAS DEL MES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalComprasMes, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"/>
                        <TextBlock Text="egreso total" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource KpiCard}"
                        BorderBrush="{DynamicResource PrimaryBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource PrimaryAlphaBrush}">
                                <TextBlock Text="📈" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="RESULTADO NETO" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ResultadoNeto, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="ventas menos compras" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1A8B5CF6">
                                <TextBlock Text="%" FontSize="14" FontWeight="Bold"
                                           Foreground="#8B5CF6"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="MARGEN BRUTO" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding MargenBrutoMes, StringFormat='{}{0:N1}%'}"
                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                            <Run Text="Ticket prom. "/>
                            <Run Text="{Binding TicketPromedio, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                 FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ KPIs — ADMINISTRADOR ══════════════════════════════════════ -->
            <Grid Grid.Row="2"
                  Visibility="{Binding MostrarSeccionAdministrador, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource PrimaryAlphaBrush}">
                                <TextBlock Text="🧾" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="VENTAS DEL MES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CantidadVentasMes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="transacciones" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource WarningAlphaBrush}">
                                <TextBlock Text="📦" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="COMPRAS DEL MES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ComprasDelMes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="órdenes emitidas" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource WarningAlphaBrush}">
                                <TextBlock Text="⏳" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="PENDIENTES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding VentasPendientes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="ventas por cobrar" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource SuccessAlphaBrush}">
                                <TextBlock Text="$" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="INGRESOS HOY" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding IngresosHoy, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="cobros del día" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ KPIs — VENDEDOR ═══════════════════════════════════════════ -->
            <Grid Grid.Row="2"
                  Visibility="{Binding MostrarSeccionVendedor, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource SuccessAlphaBrush}">
                                <TextBlock Text="$" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="MIS VENTAS HOY" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding MisVentasHoy, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                            <Run Text="{Binding MiCantidadVentasHoy, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Run Text=" ventas realizadas"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource PrimaryAlphaBrush}">
                                <TextBlock Text="💰" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="SALDO EN CAJA" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SaldoCaja, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                            <Run Text="Apertura "/>
                            <Run Text="{Binding HoraAperturaCaja, Mode=OneWay}"
                                 FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource WarningAlphaBrush}">
                                <TextBlock Text="⏳" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="PENDIENTES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding VentasPendientes}" FontSize="30" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="ventas por cobrar" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ ACCIONES RÁPIDAS — GERENTE ════════════════════════════════ -->
            <Grid Grid.Row="8"
                  Visibility="{Binding MostrarSeccionGerente, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="ACCIONES RÁPIDAS" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource QuickAction}" Click="IrReporteGerencial_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📈" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reporte Gerencial" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource QuickAction}" Click="IrCompararPeriodos_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Comparar Períodos" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Style="{StaticResource QuickAction}" Click="IrVerEquipo_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Ver Equipo" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- ══ ACCIONES RÁPIDAS — ADMINISTRADOR ═════════════════════════ -->
            <Grid Grid.Row="8"
                  Visibility="{Binding MostrarSeccionAdministrador, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="ACCIONES RÁPIDAS" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource QuickAction}" Click="NuevoProducto_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🏷" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nuevo Producto" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource QuickAction}" Click="RegistrarCompra_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📦" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Registrar Compra" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Style="{StaticResource QuickAction}" Click="ResumenDiario_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📋" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Resumen Diario" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="6" Style="{StaticResource QuickAction}" Click="IrInventario_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Inventario" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- ══ ACCIONES RÁPIDAS — VENDEDOR ═══════════════════════════════ -->
            <Grid Grid.Row="8"
                  Visibility="{Binding MostrarSeccionVendedor, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="ACCIONES RÁPIDAS" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource QuickAction}" Click="NuevaVenta_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🛒" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nueva Venta" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource QuickAction}" Click="CobrarPendiente_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="💵" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cobrar Pendiente" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" Style="{StaticResource QuickAction}" Click="NuevoCliente_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="👤" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nuevo Cliente" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- ══ ACTIVIDAD RECIENTE + PANEL SECUNDARIO ════════════════════ -->
            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Últimas ventas — todos los roles -->
                <Border Grid.Column="0" Style="{StaticResource KpiCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="20,16,20,12">
                            <StackPanel>
                                <TextBlock Text="ÚLTIMAS VENTAS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Actividad reciente"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MostrarSeccionVendedor}" Value="True">
                                                    <Setter Property="Text" Value="Mis ventas de hoy"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button Content="Ver todas →" HorizontalAlignment="Right"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    FontSize="12" Cursor="Hand"
                                    Click="IrVentasCompleto_Click"/>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding VentasRecientes}" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="38" Height="38" CornerRadius="10"
                                                    Background="{DynamicResource SurfaceBrush}">
                                                <TextBlock Text="◈" FontSize="16"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock Text="{Binding ClienteNombre, Mode=OneWay}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                    <Run Text="Venta #"/>
                                                    <Run Text="{Binding IdVenta, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding Fecha, StringFormat='HH:mm', Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding TotalFinal, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                                       FontSize="15" FontWeight="Bold"
                                                       Foreground="{DynamicResource SuccessBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Panel secundario derecho: stock critico (Admin/Gerente) o resumen caja (Vendedor) -->
                <Border Grid.Column="2" Style="{StaticResource KpiCard}" Padding="0"
                        Visibility="{Binding MostrarSeccionAdministrador, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="20,16,20,12">
                            <StackPanel>
                                <TextBlock Text="STOCK CRÍTICO" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="Requieren reposición urgente" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Content="Ver todos →" HorizontalAlignment="Right"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    FontSize="12" Cursor="Hand"
                                    Click="IrProductosStock_Click"/>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ProductosCriticosList}" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Nombre, Mode=OneWay}"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11" Margin="0,3,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                                    <Run Text="Mínimo: "/>
                                                    <Run Text="{Binding StockMinimo, Mode=OneWay}"/>
                                                    <Run Text=" unidades"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="8" Padding="12,5"
                                                    MinWidth="44" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding StockActual, Mode=OneWay}"
                                                               FontSize="16" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="White" HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="pocas"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                        <Setter Property="Text" Value="sin stock"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Panel derecho Gerente: acceso rápido a reportes -->
                <Border Grid.Column="2" Style="{StaticResource KpiCard}"
                        Visibility="{Binding MostrarSeccionGerente, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="ACCESO RÁPIDO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                        <Button Style="{StaticResource QuickAction}" Margin="0,0,0,10" Click="IrReportes_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📊" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Reportes completos" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Rentabilidad y comparativas" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource QuickAction}" Click="IrConfiguracion_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="⚙️" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Configuración" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Empresa, usuarios y roles" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Panel derecho Vendedor: resumen de caja -->
                <Border Grid.Column="2" Style="{StaticResource KpiCard}"
                        Visibility="{Binding MostrarSeccionVendedor, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="MI CAJA" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding SaldoCaja, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="saldo actual" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,20"/>
                        <Button Style="{StaticResource QuickAction}" Click="IrCaja_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="💰" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Gestionar caja" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
