<UserControl x:Class="GestionComercial.UI.Views.Main.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:DecimalToMonedaConverter   x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>

        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Padding"         Value="22,18"/>
        </Style>

        <Style x:Key="SubCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="18,14"/>
        </Style>

        <Style x:Key="QuickAction" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background"  Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Saludo -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>  <!-- KPIs operativos -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Fila finanzas (solo Gerente) -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Acciones rápidas -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Actividad + stock -->
            </Grid.RowDefinitions>

            <!-- ══ SALUDO ══ -->
            <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="14" Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Buen día, "/>
                            <Run Text="{Binding UsuarioNombre, Mode=OneWay}"
                                 Foreground="{DynamicResource PrimaryBrush}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding UsuarioRol, Mode=OneWay}"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                            <TextBlock Text="{Binding FechaHoy, Mode=OneWay}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TituloSaludo, Mode=OneWay}"
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Indicador caja -->
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="16,12" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="{DynamicResource SuccessBrush}" Margin="0,0,6,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="Caja abierta" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SaldoCaja, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,2"/>
                            <TextBlock FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="Apertura "/>
                                <Run Text="{Binding HoraAperturaCaja, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══ KPIs OPERATIVOS (todos los roles) ══ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ventas hoy -->
                <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="#1A22C55E">
                                <TextBlock Text="$" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="VENTAS HOY" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalVentasHoy, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="30" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>

                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="8,3">
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="{Binding CantidadVentasHoy, Mode=OneWay}" FontWeight="Bold"
                                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Run Text=" ventas"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Ventas mes -->
                <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1A3B82F6">
                                <TextBlock Text="📅" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="VENTAS DEL MES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalVentasMes, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="30" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>

                        <!-- Crecimiento — solo Gerente -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal"
                                    Visibility="{Binding MostrarFinanzas, Converter={StaticResource BoolToVisibility}}">
                            <Border CornerRadius="6" Padding="8,3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1A22C55E"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CrecimientoPositivo}" Value="False">
                                                <Setter Property="Background" Value="#1AEF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CrecimientoPositivo}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding CrecimientoMes, StringFormat='{}{0:+0.0;-0.0}%', Mode=OneWay}"/>
                                    <Run Text=" vs mes anterior"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="4" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Visibility="{Binding MostrarOperaciones, Converter={StaticResource BoolToVisibility}}">
                            <Run Text="{Binding CantidadVentasMes, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Run Text=" transacciones"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Pendientes -->
                <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1AF59E0B">
                                <TextBlock Text="⏳" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="PENDIENTES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Text="{Binding VentasPendientes, Mode=OneWay}"
                                   FontSize="30" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>

                        <TextBlock Grid.Row="4" Text="ventas por cobrar" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Stock crítico -->
                <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1AEF4444">
                                <TextBlock Text="⚠" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="STOCK CRÍTICO" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Text="{Binding ProductosCriticos, Mode=OneWay}"
                                   FontSize="30" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"/>

                        <TextBlock Grid.Row="4" Text="productos bajo mínimo" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ FILA FINANZAS (solo Gerente) ══ -->
            <Grid Grid.Row="4"
                  Visibility="{Binding MostrarFinanzas, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Compras mes -->
                <Border Grid.Column="0" Style="{StaticResource SubCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="COMPRAS DEL MES" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalComprasMes, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource ErrorBrush}" Margin="0,8,0,4"/>
                            <TextBlock Text="egreso total" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Ver →" VerticalAlignment="Bottom"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource PrimaryBrush}" FontSize="12" Cursor="Hand"
                                Click="IrCompras_Click"/>
                    </Grid>
                </Border>

                <!-- Resultado neto -->
                <Border Grid.Column="2" Style="{StaticResource SubCard}"
                        BorderBrush="{DynamicResource PrimaryBrush}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="RESULTADO NETO" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding ResultadoNeto, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,4"/>
                            <TextBlock Text="ventas menos compras" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Margen + Ticket -->
                <Border Grid.Column="4" Style="{StaticResource SubCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MARGEN BRUTO" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding MargenBrutoMes, StringFormat='{}{0:N1}%'}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,4"/>
                            <TextBlock Text="este mes" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="{DynamicResource BorderBrush}" Width="1" Margin="0,4"/>

                        <StackPanel Grid.Column="2" Margin="14,0,0,0">
                            <TextBlock Text="TICKET PROM." FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TicketPromedio, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4"/>
                            <TextBlock Text="por venta" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ ACCIONES RÁPIDAS ══ -->
            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ACCIONES RÁPIDAS" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Nueva Venta — todos -->
                    <Button Grid.Column="0" Style="{StaticResource QuickAction}" Click="NuevaVenta_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🛒" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nueva Venta" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Caja — todos -->
                    <Button Grid.Column="2" Style="{StaticResource QuickAction}" Click="IrCaja_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="💰" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Caja" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Clientes — todos -->
                    <Button Grid.Column="4" Style="{StaticResource QuickAction}" Click="IrClientes_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Clientes" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Compras — Gerente y Admin -->
                    <Button Grid.Column="6" Style="{StaticResource QuickAction}"
                            Visibility="{Binding MostrarOperaciones, Converter={StaticResource BoolToVisibility}}"
                            Click="IrCompras_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📦" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Compras" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Reportes — solo Gerente y Admin -->
                    <Button Grid.Column="8" Style="{StaticResource QuickAction}"
                            Visibility="{Binding MostrarOperaciones, Converter={StaticResource BoolToVisibility}}"
                            Click="IrReportes_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reportes" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Vendedor: en lugar de Compras/Reportes muestra Productos -->
                    <Button Grid.Column="6" Style="{StaticResource QuickAction}"
                            Visibility="{Binding EsVendedor, Converter={StaticResource BoolToVisibility}}"
                            Click="IrProductos_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🏷" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Productos" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- ══ ACTIVIDAD + STOCK ══ -->
            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Actividad reciente -->
                <Border Grid.Column="0" Style="{StaticResource KpiCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,16,20,12">
                            <StackPanel>
                                <TextBlock Text="ÚLTIMAS VENTAS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="Actividad reciente de hoy" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Content="Ver todas →" HorizontalAlignment="Right"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    FontSize="12" Cursor="Hand"
                                    Click="IrVentasCompleto_Click"/>
                        </Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding VentasRecientes}"
                                      Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10"
                                                    Background="{DynamicResource SurfaceBrush}">
                                                <TextBlock Text="◈" FontSize="16"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <Run Text="{Binding ClienteNombre, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                    <Run Text="Venta #"/>
                                                    <Run Text="{Binding IdVenta, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding Fecha, StringFormat='HH:mm', Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       Text="{Binding TotalFinal, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                                       FontSize="15" FontWeight="Bold"
                                                       Foreground="{DynamicResource SuccessBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Stock crítico -->
                <Border Grid.Column="2" Style="{StaticResource KpiCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,16,20,12">
                            <StackPanel>
                                <TextBlock Text="STOCK CRÍTICO" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="Requieren reposición urgente" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Content="Ver todos →" HorizontalAlignment="Right"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    FontSize="12" Cursor="Hand"
                                    Click="IrProductosStock_Click"/>
                        </Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ProductosCriticosList}"
                                      Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Nombre, Mode=OneWay}"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11" Margin="0,3,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                                    <Run Text="Mínimo: "/>
                                                    <Run Text="{Binding StockMinimo, Mode=OneWay}"/>
                                                    <Run Text=" unidades"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Badge stock -->
                                            <Border Grid.Column="1" CornerRadius="8" Padding="12,5"
                                                    MinWidth="44" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding StockActual, Mode=OneWay}"
                                                               FontSize="16" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="White" HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="pocas"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                        <Setter Property="Text" Value="sin stock"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
