<UserControl x:Class="GestionComercial.UI.Views.Main.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
    </UserControl.Resources>

    <Grid>

        <!-- ── Loading overlay ─────────────────────────────────────────────── -->
        <Grid Panel.ZIndex="10"
              Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{DynamicResource PrimaryBrush}"
                             BorderThickness="0"
                             Background="{DynamicResource SurfaceBrush}"/>
                <TextBlock Text="Cargando dashboard..."
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="14" HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Bienvenida -->
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>  <!-- Tarjetas métricas -->
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>  <!-- Error (si hay) -->
                    <RowDefinition Height="Auto"/>  <!-- Accesos rápidos -->
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════════════════════════
                     FILA 0 — Bienvenida + fecha + botón actualizar
                ═══════════════════════════════════════════════════════════ -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👋 Bienvenido, "
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding UsuarioNombre}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="📅 "
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding FechaHoy}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="  ·  "
                                       FontSize="14"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding HoraActual}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Botón Actualizar — Caliburn lo conecta a DashboardViewmodel.Actualizar() -->
                    <Button x:Name="Actualizar"
                            Grid.Column="1"
                            Content="⟳  Actualizar"
                            Style="{StaticResource PrimaryButton}"
                            Height="40" Padding="18,0"
                            FontSize="13"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- ══════════════════════════════════════════════════════════
                     FILA 2 — Tarjetas métricas
                ═══════════════════════════════════════════════════════════ -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tarjeta: Total ventas del día -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="14" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Border Width="40" Height="40" Background="#1A38BDF8" CornerRadius="10">
                                    <TextBlock Text="💳" FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Ventas del Día"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Text="{Binding TotalVentasDia, Converter={StaticResource DecimalToMoneda}}"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                            <!-- Badge comparación vs ayer -->
                            <Border Grid.Row="4" CornerRadius="6" Padding="8,4"
                                    HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1AEF4444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ComparacionPositiva}" Value="True">
                                                <Setter Property="Background" Value="#1A22C55E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ComparacionAyer}"
                                           FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ComparacionPositiva}" Value="True">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Tarjeta: Transacciones -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="14" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Border Width="40" Height="40" Background="#1A22C55E" CornerRadius="10">
                                    <TextBlock Text="🧾" FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Transacciones"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Text="{Binding CantidadVentasDia}"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>

                            <TextBlock Grid.Row="4" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="Ticket promedio:"/>
                                <Run Text="{Binding TicketPromedio, Converter={StaticResource DecimalToMoneda}}"
                                     FontWeight="SemiBold"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Tarjeta: Estado de Caja -->
                    <Border Grid.Column="4"
                            BorderThickness="1" CornerRadius="14" Padding="24">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"    Value="#120A0A"/>
                                <Setter Property="BorderBrush"   Value="#EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CajaAbierta}" Value="True">
                                        <Setter Property="Background"  Value="#0A120A"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1AEF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CajaAbierta}" Value="True">
                                                    <Setter Property="Background" Value="#1A22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="💰" FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Estado de Caja"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <TextBlock Text="{Binding EstadoCajaIcono}"
                                           FontSize="22" VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding EstadoCajaTexto}"
                                           FontSize="26" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CajaAbierta}" Value="True">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Row="4" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="Apertura:"/>
                                <Run Text="{Binding CajaApertura}" FontWeight="SemiBold"/>
                                <Run Text="  ·  Monto inicial:"/>
                                <Run Text="{Binding MontoInicial, Converter={StaticResource DecimalToMoneda}}"
                                     FontWeight="SemiBold"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════════════════════════
                     FILA 4 — Error (solo visible si hay error)
                ═══════════════════════════════════════════════════════════ -->
                <Border Grid.Row="4"
                        Visibility="{Binding TieneError, Converter={StaticResource BoolToVisibility}}"
                        Background="#1A0A0A"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,10" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠  "
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontSize="13" TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════════════════════
                     FILA 5 — Accesos rápidos
                ═══════════════════════════════════════════════════════════ -->
                <Border Grid.Row="5"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="14" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Accesos rápidos"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,20"/>
                        <WrapPanel>

                            <Border Width="150" Height="110"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="12"
                                    Margin="0,0,12,12" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding ActualizarCommand}"/>
                                </Border.InputBindings>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="💳" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Nueva Venta"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Width="150" Height="110"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="12"
                                    Margin="0,0,12,12" Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📦" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Productos"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Width="150" Height="110"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="12"
                                    Margin="0,0,12,12" Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🛒" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Nueva Compra"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Width="150" Height="110"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="12"
                                    Margin="0,0,12,12" Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="👥" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Clientes"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Width="150" Height="110"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="12"
                                    Margin="0,0,0,12" Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📈" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Reportes"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                        </WrapPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
