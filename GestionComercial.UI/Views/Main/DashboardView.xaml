<UserControl x:Class="GestionComercial.UI.Views.Main.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:DecimalToMonedaConverter x:Key="DecimalToMoneda"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Card métrica grande -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Padding"         Value="22,18"/>
        </Style>

        <!-- Card secundaria -->
        <Style x:Key="SubCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="18,14"/>
        </Style>

        <!-- Fila actividad reciente -->
        <Style x:Key="ActivityRow" TargetType="Border">
            <Setter Property="Padding"      Value="14,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin"       Value="0,2"/>
            <Setter Property="Background"   Value="Transparent"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Saludo -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>  <!-- Métricas principales -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Fila secundaria -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Actividad + stock crítico -->
            </Grid.RowDefinitions>

            <!-- SALUDO -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Text="Buen día, "/>
                        <Run Text="{Binding UsuarioNombre, Mode=OneWay}"
                             Foreground="{DynamicResource PrimaryBrush}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding FechaHoy, Mode=OneWay}"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

               
            </Grid>

            <!-- MÉTRICAS PRINCIPALES -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ventas hoy -->
                <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="VENTAS HOY" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalVentasHoy, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="32" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>

                        <TextBlock Grid.Row="4" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding CantidadVentasHoy, Mode=OneWay}"/>
                            <Run Text=" transacciones"/>
                        </TextBlock>

                        <!-- Barra progreso vs ayer -->
                        <ProgressBar Grid.Row="6" Height="3" Value="{Binding ProgresoVentasHoy, Mode=OneWay}"
                                     Maximum="100" BorderThickness="0"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource SuccessBrush}"/>
                    </Grid>
                </Border>

                <!-- Ventas mes -->
                <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="VENTAS MES" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalVentasMes, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>

                        <TextBlock Grid.Row="4" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding CantidadVentasMes, Mode=OneWay}"/>
                            <Run Text=" transacciones"/>
                        </TextBlock>

                        <ProgressBar Grid.Row="6" Height="3" Value="{Binding ProgresoVentasMes, Mode=OneWay}"
                                     Maximum="100" BorderThickness="0"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource PrimaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Caja actual -->
                <Border Grid.Column="4" Style="{StaticResource MetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="CAJA ACTUAL" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Border Background="{DynamicResource SuccessBrush}"
                                    CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                <TextBlock Text="ABIERTA" FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding SaldoCaja, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="32" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>

                        <TextBlock Grid.Row="4" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="Apertura: "/>
                            <Run Text="{Binding HoraAperturaCaja, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Productos críticos -->
                <Border Grid.Column="6" Style="{StaticResource MetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="STOCK CRÍTICO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding ProductosCriticos, Mode=OneWay}"
                                   FontSize="32" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"/>

                        <TextBlock Grid.Row="4" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="productos requieren atención"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- FILA SECUNDARIA: Ticket promedio + Margen + Pendientes -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SubCard}">
                    <StackPanel>
                        <TextBlock Text="TICKET PROMEDIO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TicketPromedio, Converter={StaticResource DecimalToMoneda}}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="por venta este mes" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SubCard}">
                    <StackPanel>
                        <TextBlock Text="MARGEN BRUTO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding MargenBrutoMes, StringFormat='{}{0:N1}%'}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="este mes" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource SubCard}">
                    <StackPanel>
                        <TextBlock Text="VENTAS PENDIENTES" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding VentasPendientes, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="por cobrar" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- FILA INFERIOR: Actividad reciente + Stock crítico -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Actividad reciente -->
                <Border Grid.Column="0" Style="{StaticResource MetricCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="20,16,20,0">
                            <TextBlock Text="ACTIVIDAD RECIENTE" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="IrVentasCompleto" Content="Ver todo →"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    FontSize="12" Cursor="Hand"
                                    HorizontalAlignment="Right"/>
                        </Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding VentasRecientes}"
                                      Margin="12,10,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource ActivityRow}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Ícono -->
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    CornerRadius="8" Background="{DynamicResource SurfaceBrush}">
                                                <TextBlock Text="◈" FontSize="16"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <TextBlock FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <Run Text="Venta #"/>
                                                    <Run Text="{Binding IdVenta, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding ClienteNombre, Mode=OneWay}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding TotalFinal, Converter={StaticResource DecimalToMoneda}, Mode=OneWay}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SuccessBrush}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding Fecha, StringFormat='HH:mm', Mode=OneWay}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Stock crítico -->
                <Border Grid.Column="2" Style="{StaticResource MetricCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="18,16,18,0">
                            <TextBlock Text="STOCK CRÍTICO" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="IrProductosStock" Content="Ver todo →"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    FontSize="12" Cursor="Hand"
                                    HorizontalAlignment="Right"/>
                        </Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ProductosCriticosList}"
                                      Margin="10,10,10,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,10" CornerRadius="8" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Nombre, Mode=OneWay}"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11" Margin="0,3,0,0">
                                                    <Run Text="Mín: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <Run Text="{Binding StockMinimo, Mode=OneWay}"
                                                         Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    CornerRadius="6" Padding="10,4"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StockActual}" Value="0">
                                                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StockActual, Mode=OneWay}"
                                                           FontSize="13" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
