<UserControl x:Class="GestionComercial.UI.Views.Main.Ventas.VentaListadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:EstadoToColorConverter    x:Key="EstadoToColor"/>

        <!-- Badge de estado -->
        <Style x:Key="EstadoBadge" TargetType="Border">
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Botón icono de acción en DataGrid -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo DataGrid -->
        <Style x:Key="VentasGrid" TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="RowBackground"         Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#0A1628"/>
            <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="SelectionUnit"         Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="RowHeight"             Value="52"/>
            <Setter Property="ColumnHeaderHeight"    Value="44"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="16,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground"   Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A3A5C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón filtro -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Tarjetas resumen -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Barra filtros -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Paginación -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             FILA 0 — Tarjetas resumen
        ════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total ventas del día -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="💰  Ventas Hoy"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalVentasHoy, Converter={StaticResource DecimalToMoneda}}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#4ADE80"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding CantidadVentasHoy, StringFormat='{}{0} transacciones'}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Total del mes -->
            <Border Grid.Column="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="📅  Ventas del Mes"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalVentasMes, Converter={StaticResource DecimalToMoneda}}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding CantidadVentasMes, StringFormat='{}{0} transacciones'}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Pendientes -->
            <Border Grid.Column="4"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="⏳  Pendientes"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding VentasPendientes}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#FACC15"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="por cobrar"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Canceladas -->
            <Border Grid.Column="6"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="❌  Canceladas"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding VentasCanceladas}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="este mes"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════
             FILA 2 — Barra de filtros
        ════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Búsqueda -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="12,0,8,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TextoBusqueda"
                                 Grid.Column="1"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontSize="13" VerticalContentAlignment="Center"
                                 Padding="0,0,12,0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="HintBrush" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Buscar por cliente, N° venta..."
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Fecha desde -->
                <Border Grid.Column="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Height="40"
                        Padding="12,0">
                    <DatePicker x:Name="FechaDesde"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                FontSize="13"
                                VerticalAlignment="Center"/>
                </Border>

                <!-- Fecha hasta -->
                <Border Grid.Column="4"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Height="40"
                        Padding="12,0">
                    <DatePicker x:Name="FechaHasta"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                FontSize="13"
                                VerticalAlignment="Center"/>
                </Border>

                <!-- Estado -->
                <ComboBox x:Name="FiltroEstado"
                          Grid.Column="6"
                          Style="{StaticResource FilterCombo}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Todos"/>
                    <ComboBoxItem Content="Completada"/>
                    <ComboBoxItem Content="Pendiente"/>
                    <ComboBoxItem Content="Cancelada"/>
                </ComboBox>

                <!-- Buscar -->
                <Button x:Name="Buscar"
                        Grid.Column="8"
                        Content="Buscar"
                        Height="40" Padding="20,0"
                        FontSize="13"
                        Style="{StaticResource PrimaryButton}"/>

                <!-- Nueva Venta -->
                <Button x:Name="NuevaVenta"
                        Grid.Column="10"
                        Height="40" Padding="20,0"
                        FontSize="13"
                        Style="{StaticResource PrimaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Nueva Venta" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             FILA 4 — DataGrid ventas
        ════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12"
                ClipToBounds="True">

            <!-- Loading overlay -->
            <Grid>
                <DataGrid x:Name="VentaSeleccionada"
                          Style="{StaticResource VentasGrid}"
                          ItemsSource="{Binding Ventas}">
                    <DataGrid.Columns>

                        <!-- N° Venta -->
                        <DataGridTextColumn Header="N° Venta"
                                            Binding="{Binding IdVenta}"
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Fecha -->
                        <DataGridTextColumn Header="Fecha"
                                            Binding="{Binding Fecha, StringFormat='dd/MM/yyyy HH:mm'}"
                                            Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Cliente -->
                        <DataGridTextColumn Header="Cliente"
                                            Binding="{Binding ClienteNombre}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Vendedor -->
                        <DataGridTextColumn Header="Vendedor"
                                            Binding="{Binding UsuarioNombre}"
                                            Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Total -->
                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding TotalFinal, Converter={StaticResource DecimalToMoneda}}"
                                            Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4ADE80"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,16,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Estado -->
                        <DataGridTemplateColumn Header="Estado" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource EstadoBadge}"
                                            Background="{Binding Estado, Converter={StaticResource EstadoToColor}}">
                                        <TextBlock Text="{Binding Estado}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Acciones -->
                        <DataGridTemplateColumn Header="Acciones" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="👁"
                                                Style="{StaticResource ActionButton}"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                ToolTip="Ver detalle"
                                                Tag="{Binding}"/>
                                        <Button Content="🖨"
                                                Style="{StaticResource ActionButton}"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                ToolTip="Imprimir"
                                                Tag="{Binding}"
                                                Margin="4,0,0,0"/>
                                        <Button Content="❌"
                                                Style="{StaticResource ActionButton}"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                ToolTip="Cancelar venta"
                                                Tag="{Binding}"
                                                Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading overlay -->
                <Border Background="#CC0F1419"
                        CornerRadius="12"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200" Height="4"
                                     Foreground="{DynamicResource PrimaryBrush}"
                                     BorderThickness="0"
                                     Background="{DynamicResource SurfaceBrush}"/>
                        <TextBlock Text="Cargando ventas..."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             FILA 5 — Paginación
        ════════════════════════════════════════ -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="13">
                <Run Text="Mostrando "/>
                <Run Text="{Binding VentasMostradas, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Run Text=" de "/>
                <Run Text="{Binding TotalVentas, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Run Text=" ventas"/>
            </TextBlock>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="PaginaAnterior"
                        Content="← Anterior"
                        Height="36" Padding="16,0"
                        FontSize="13"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0"/>
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16,0" Height="36">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13">
                        <Run Text="Página "/>
                        <Run Text="{Binding PaginaActual, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" de "/>
                        <Run Text="{Binding TotalPaginas, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </Border>
                <Button x:Name="PaginaSiguiente"
                        Content="Siguiente →"
                        Height="36" Padding="16,0"
                        FontSize="13"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
