<Window x:Class="GestionComercial.UI.Views.Main.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cal="http://www.caliburnproject.org"
        xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
        Title="GestionComercial"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <converters:NullVisibilityConverter   x:Key="NullToVisibility"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,1">
                            <ContentPresenter Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Badge de rol coloreado -->
        <Style x:Key="RolBadge" TargetType="Border">
            <Setter Property="CornerRadius"      Value="4"/>
            <Setter Property="Padding"           Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <!-- Color por defecto: Vendedor (gris) -->
            <Setter Property="Background"        Value="{DynamicResource TextSecondaryBrush}"/>
            <Style.Triggers>
                <!-- Gerente: verde -->
                <DataTrigger Binding="{Binding EsGerente}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                </DataTrigger>
                <!-- Administrador: azul primario -->
                <DataTrigger Binding="{Binding EsAdministrador}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                </DataTrigger>
                <!-- Vendedor: gris -->
                <DataTrigger Binding="{Binding EsVendedor}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ SIDEBAR ══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>   <!-- PRINCIPAL -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>   <!-- CATALOGO -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>   <!-- GESTION -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>   <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Padding="16,20,16,0">
                    <StackPanel>
                        <TextBlock Text="⬡" FontSize="22" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="GestiónComercial" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding UsuarioSucursal}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── PRINCIPAL ── -->
                <StackPanel Grid.Row="2" Margin="10,0">
                    <TextBlock Text="PRINCIPAL" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,8"/>

                    <!-- Dashboard: todos los roles -->
                    <Button x:Name="IrDashboard" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Ventas: Gerente y Vendedor -->
                    <Button x:Name="IrVentas" Style="{StaticResource NavButton}"
                            Visibility="{Binding MostrarVentas, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◈" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Ventas" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Caja: todos los roles -->
                    <Button x:Name="IrCaja" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▣" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Caja" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Compras: Gerente y Administrador -->
                    <Button x:Name="IrCompras" Style="{StaticResource NavButton}"
                            Visibility="{Binding MostrarCompras, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◉" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Compras" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- ── CATÁLOGO ── -->
                <StackPanel Grid.Row="4" Margin="10,0"
                            Visibility="{Binding MostrarProductos, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="CATÁLOGO" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,8"/>

                    <!-- Productos: solo Gerente -->
                    <Button x:Name="IrProductos" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◧" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Productos" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Inventario: solo Gerente (en este bloque) -->
                    <Button x:Name="IrInventario" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◪" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Inventario" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Inventario para Administrador (fuera del bloque Catálogo) -->
                <StackPanel Grid.Row="4" Margin="10,0"
                            Visibility="{Binding EsAdministrador, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="CATÁLOGO" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,8"/>
                    <Button x:Name="IrInventarioAdmin" Style="{StaticResource NavButton}"
                            Click="IrInventario_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◪" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Inventario" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- ── GESTIÓN ── -->
                <StackPanel Grid.Row="6" Margin="10,0">
                    <TextBlock Text="GESTIÓN" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,8"/>

                    <!-- Clientes: todos los roles -->
                    <Button x:Name="IrClientes" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="○" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Clientes" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Proveedores: Gerente y Administrador -->
                    <Button x:Name="IrProveedores" Style="{StaticResource NavButton}"
                            Visibility="{Binding MostrarProveedores, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◌" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Proveedores" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Reportes: Gerente y Administrador (cada uno ve el suyo via ShellViewModel.IrReportes) -->
                    <Button x:Name="IrReportes" Style="{StaticResource NavButton}"
                            Visibility="{Binding MostrarReportes, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◫" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Reportes" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Configuración: Gerente y Administrador -->
                    <Button x:Name="IrConfiguracion" Style="{StaticResource NavButton}"
                            Visibility="{Binding MostrarConfiguracion, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊙" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Configuración" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- ── Footer usuario ── -->
                <Border Grid.Row="8" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar inicial -->
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                                Background="{DynamicResource PrimaryBrush}">
                            <TextBlock Text="{Binding UsuarioInicial}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource BackgroundBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Nombre + badge de rol -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding UsuarioNombre}" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Border Style="{StaticResource RolBadge}" HorizontalAlignment="Left" Margin="0,3,0,0">
                                <TextBlock Text="{Binding UsuarioRol}" FontSize="9" FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <!-- Botón cerrar sesión -->
                        <Button Grid.Column="2" x:Name="CerrarSesion" Content="⏻" FontSize="16"
                                Width="30" Height="30" Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Cursor="Hand" ToolTip="Cerrar sesión">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#1AEF4444"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Divisor vertical -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>

            <!-- ══ ÁREA CONTENIDO ══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Grid Grid.Row="0" Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveItem.Titulo, FallbackValue='Dashboard'}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text=" · " FontSize="15" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Visibility="{Binding ActiveItem.Subtitulo, Converter={StaticResource NullToVisibility}}"/>
                        <TextBlock Text="{Binding ActiveItem.Subtitulo}" FontSize="15"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeWindow" Content="─"
                                Style="{StaticResource WindowButton}" Click="Minimize_Click"/>
                        <Button x:Name="MaximizeWindow" Content="□"
                                Style="{StaticResource WindowButton}" Click="Maximize_Click" Margin="4,0"/>
                        <Button Content="✕" Style="{StaticResource WindowButton}" Click="Close_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <Rectangle Grid.Row="1" Fill="{DynamicResource BorderBrush}"/>
                <ContentControl Grid.Row="2" x:Name="ActiveItem" Margin="0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
