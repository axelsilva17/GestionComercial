<Window x:Class="GestionComercial.UI.Views.Main.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gestión Comercial"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinWidth="1200"
        MinHeight="700"
        d:Background="#0F1419">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0F1419"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1A2332"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#243447"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0F2FE"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7DD3FC"/>
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="#38BDF8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2A3D52"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#2A3D52"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#38BDF8"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="#000000"/>

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="SidebarMenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="16"
            Effect="{DynamicResource CardShadow}"
            Opacity="0"
            Loaded="Window_Loaded">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== SIDEBAR IZQUIERDO ========== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    CornerRadius="16,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">

                <Grid Margin="0,24,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER CON LOGO -->
                    <StackPanel Grid.Row="0" Margin="24,0,24,24">
                        <Border Width="48" Height="48"
                                Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="12"
                                Margin="0,0,0,16">
                            <TextBlock Text="GC"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Gestión Comercial"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Sistema de gestión"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- MENÚ DE NAVEGACIÓN -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12,0">
                        <StackPanel>

                            <!-- Sección Principal -->
                            <TextBlock Text="PRINCIPAL"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="12,0,0,8"/>

                            <!--
                                CAMBIO CLAVE: x:Name="IrDashboard"
                                Caliburn conecta esto al método IrDashboard() del Shellusing GestionComercial.UI.using GestionComercial.UI.ViewModels
                                Sin Click handler — Caliburn lo maneja solo.
                            -->
                            <Button x:Name="IrDashboard"
                                    Tag="Active"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Dashboard" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Sección Operaciones -->
                            <TextBlock Text="OPERACIONES"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="12,20,0,8"/>

                            <Button x:Name="IrVentas"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💳" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Ventas" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="IrCompras"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛒" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Compras" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="IrCaja"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💰" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Caja" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Sección Gestión -->
                            <TextBlock Text="GESTIÓN"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="12,20,0,8"/>

                            <Button x:Name="IrProductos"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Productos" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="IrInventario"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Inventario" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="IrClientes"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Clientes" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="IrProveedores"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏢" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Proveedores" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Sección Análisis -->
                            <TextBlock Text="ANÁLISIS"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="12,20,0,8"/>

                            <Button x:Name="IrReportes"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Reportes" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Separador -->
                            <Border Height="1"
                                    Background="{DynamicResource BorderBrush}"
                                    Margin="12,16"/>

                            <Button x:Name="IrConfiguracion"
                                    Style="{StaticResource SidebarMenuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="18" Margin="0,0,14,0"/>
                                    <TextBlock Text="Configuración" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- FOOTER CON USUARIO -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12"
                            Padding="14"
                            Margin="16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="42" Height="42"
                                    Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="10">
                                <TextBlock Text="A"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UsuarioNombre}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding UsuarioSucursal}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="⏻"
                                    Width="36" Height="36"
                                    FontSize="18"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Logout_Click"
                                    ToolTip="Cerrar sesión">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== CONTENIDO PRINCIPAL ========== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER CON CONTROLES DE VENTANA -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        Padding="32,24"
                        MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Controles de ventana -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="🔔"
                                    Width="40" Height="40" FontSize="18"
                                    Margin="0,0,8,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0" Cursor="Hand"
                                    ToolTip="Notificaciones">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Border Width="1" Height="24"
                                    Background="{DynamicResource BorderBrush}"
                                    Margin="8,0"/>

                            <Button Content="—"
                                    Width="40" Height="40" FontSize="20"
                                    Margin="8,0,0,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="Minimize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="🗖"
                                    Width="40" Height="40" FontSize="16"
                                    Margin="8,0,0,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="Maximize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="✕"
                                    Width="40" Height="40" FontSize="18"
                                    Margin="8,0,0,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="Close_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--
                    CAMBIO CLAVE: x:Name="ActiveItem"
                    Caliburn usa este nombre para bindear el using GestionComercial.UI.using GestionComercial.UI.Viewmodels. activo
                    y renderizar su View correspondiente automáticamente.
                -->
                <ContentControl x:Name="ActiveItem"
                                Grid.Row="1"
                                Margin="32,0,32,32"/>
            </Grid>
        </Grid>
    </Border>
</Window>
