<Window x:Class="GestionComercial.UI.Views.Main.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cal="http://www.caliburnproject.org"
        Title="GestionComercial"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>

        <!-- Botón de nav lateral -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,1">
                            <ContentPresenter Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón nav ACTIVO -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <!-- Botón control ventana -->
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Marco exterior con borde sutil -->
    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>   <!-- Sidebar nav -->
                <ColumnDefinition Width="1"/>     <!-- Divisor -->
                <ColumnDefinition Width="*"/>     <!-- Contenido -->
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════
                 SIDEBAR NAVEGACIÓN
            ════════════════════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Logo -->
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>  <!-- Sección principal -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- Sección inventario -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- Sección gestión -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>  <!-- Footer usuario -->
                </Grid.RowDefinitions>

                <!-- Logo / Nombre sistema -->
                <Border Grid.Row="0" Padding="16,20,16,0">
                    <StackPanel>
                        <TextBlock Text="⬡" FontSize="22"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="GestiónComercial"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding UsuarioSucursal}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Sección PRINCIPAL -->
                <StackPanel Grid.Row="2" Margin="10,0">
                    <TextBlock Text="PRINCIPAL" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="12,0,0,8"/>

                    <Button x:Name="IrDashboard" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IrVentas" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◈" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Ventas" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IrCaja" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▣" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Caja" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IrCompras" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◉" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Compras" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Sección CATÁLOGO -->
                <StackPanel Grid.Row="4" Margin="10,0">
                    <TextBlock Text="CATÁLOGO" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="12,0,0,8"/>

                    <Button x:Name="IrProductos" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◧" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Productos" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IrInventario" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◪" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Inventario" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Sección GESTIÓN -->
                <StackPanel Grid.Row="6" Margin="10,0">
                    <TextBlock Text="GESTIÓN" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="12,0,0,8"/>

                    <Button x:Name="IrClientes" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="○" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Clientes" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IrProveedores" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◌" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Proveedores" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IrReportes" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◫" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Reportes" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IrConfiguracion" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊙" FontSize="15" VerticalAlignment="Center" Width="22"/>
                            <TextBlock Text="Configuración" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer usuario -->
                <Border Grid.Row="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                                Background="{DynamicResource PrimaryBrush}">
                            <TextBlock Text="{Binding UsuarioInicial}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource BackgroundBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding UsuarioNombre}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding UsuarioRol}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="2" x:Name="CerrarSesion"
                                Content="⏻" FontSize="16"
                                Width="30" Height="30"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Cursor="Hand" ToolTip="Cerrar sesión">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#1AEF4444"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Divisor vertical -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>

            <!-- ═══════════════════════════════
                 ÁREA DE CONTENIDO
            ════════════════════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>   <!-- Topbar -->
                    <RowDefinition Height="1"/>    <!-- Divisor -->
                    <RowDefinition Height="*"/>    <!-- Contenido activo -->
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Grid Grid.Row="0" Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Breadcrumb / título -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveItem.Titulo, FallbackValue='Dashboard'}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text=" · "
                                   FontSize="15"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Visibility="{Binding ActiveItem.Subtitulo}"/>
                        <TextBlock Text="{Binding ActiveItem.Subtitulo}"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Controles ventana -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeWindow" Content="─"
                                Style="{StaticResource WindowButton}"
                                Click="Minimize_Click"/>
                        <Button x:Name="MaximizeWindow" Content="□"
                                Style="{StaticResource WindowButton}"
                                Click="Maximize_Click" Margin="4,0"/>
                        <Button Content="✕" Style="{StaticResource WindowButton}"
                                Click="Close_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Divisor -->
                <Rectangle Grid.Row="1" Fill="{DynamicResource BorderBrush}"/>

                <!-- Contenido del módulo activo -->
                <ContentControl Grid.Row="2"
                                x:Name="ActiveItem"
                                Margin="24,20,24,20"/>
            </Grid>
        </Grid>
    </Border>
</Window>
