<Window x:Class="GestionComercial.UI.Views.Main.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión Comercial"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinWidth="1024"
        MinHeight="600">

    <Window.Resources>
        <!-- Animación de entrada del sidebar -->
        <Storyboard x:Key="SidebarIn">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-260"
                             To="0"
                             Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="16"
            Effect="{DynamicResource CardShadow}">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== SIDEBAR ========== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    CornerRadius="16,0,0,16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    RenderTransformOrigin="0,0.5"
                    Loaded="Sidebar_Loaded">
                
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>

                <Grid Margin="0,20,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header con logo -->
                    <StackPanel Grid.Row="0" Margin="20,0,20,24">
                        <Border Width="40"
                                Height="40"
                                Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="10"
                                Margin="0,0,0,12">
                            <TextBlock Text="GC"
                                     FontSize="16"
                                     FontWeight="Bold"
                                     Foreground="White"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Gestión Comercial"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Sistema de gestión"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Menú de navegación -->
                    <ScrollViewer Grid.Row="1"
                                VerticalScrollBarVisibility="Auto"
                                Margin="12,0">
                        <StackPanel>
                            <!-- Dashboard -->
                            <Button x:Name="BtnDashboard"
                                    Tag="Active"
                                    Click="MenuButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="16,12"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="10"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="Tag" Value="Active">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Ventas -->
                            <Button x:Name="BtnVentas" Click="MenuButton_Click" Style="{StaticResource ResourceKey={x:Type Button}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💰" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Ventas" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Productos -->
                            <Button x:Name="BtnProductos" Click="MenuButton_Click" Style="{StaticResource ResourceKey={x:Type Button}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Productos" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Clientes -->
                            <Button x:Name="BtnClientes" Click="MenuButton_Click" Style="{StaticResource ResourceKey={x:Type Button}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Clientes" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Proveedores -->
                            <Button x:Name="BtnProveedores" Click="MenuButton_Click" Style="{StaticResource ResourceKey={x:Type Button}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏢" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Proveedores" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Inventario -->
                            <Button x:Name="BtnInventario" Click="MenuButton_Click" Style="{StaticResource ResourceKey={x:Type Button}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Inventario" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Reportes -->
                            <Button x:Name="BtnReportes" Click="MenuButton_Click" Style="{StaticResource ResourceKey={x:Type Button}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Reportes" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Separador -->
                            <Border Height="1"
                                    Background="{DynamicResource BorderBrush}"
                                    Margin="16,12"/>

                            <!-- Configuración -->
                            <Button x:Name="BtnConfiguracion" Click="MenuButton_Click" Style="{StaticResource ResourceKey={x:Type Button}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Configuración" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer con usuario -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="36"
                                    Height="36"
                                    Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="8">
                                <TextBlock Text="A"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         Foreground="White"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Admin"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Administrador"
                                         FontSize="11"
                                         Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="⏻"
                                    Width="32"
                                    Height="32"
                                    FontSize="16"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Logout_Click"
                                    ToolTip="Cerrar sesión">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== CONTENIDO PRINCIPAL ========== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header con título y controles de ventana -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        Padding="24,20"
                        MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Título de sección -->
                        <TextBlock x:Name="PageTitle"
                                 Text="Dashboard"
                                 FontSize="24"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center"/>

                        <!-- Controles de ventana -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="—"
                                    Width="36"
                                    Height="36"
                                    FontSize="16"
                                    Margin="0,0,8,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Minimize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="🗖"
                                    Width="36"
                                    Height="36"
                                    FontSize="14"
                                    Margin="0,0,8,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Maximize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="✕"
                                    Width="36"
                                    Height="36"
                                    FontSize="16"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="Close_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Contenido de la página -->
                <ContentControl x:Name="PageContent"
                              Grid.Row="1"
                              Margin="24,0,24,24"/>
            </Grid>
        </Grid>
    </Border>
</Window>
