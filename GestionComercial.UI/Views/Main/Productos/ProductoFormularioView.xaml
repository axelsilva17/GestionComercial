<UserControl x:Class="GestionComercial.UI.Views.Main.Productos.ProductoFormularioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>

        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="Background"               Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width"           Value="44"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="18"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FILA 0 — Título + volver -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="Volver"
                        Grid.Column="0"
                        Content="← Volver"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14" Cursor="Hand"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0"
                        Style="{StaticResource SecondaryButton}"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TituloFormulario, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SubtituloFormulario, Mode=OneWay}"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- FILA 2 — Información del producto -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="24">
                <StackPanel>

                    <TextBlock Text="Información del Producto"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,24"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nombre -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Nombre del Producto *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="Nombre" Style="{StaticResource FormTextBox}"/>
                        </StackPanel>

                        <!-- SKU -->
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="SKU" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SKU" Style="{StaticResource FormTextBox}"/>
                                <Button x:Name="GenerarSKU"
                                        Grid.Column="1"
                                        Content="⟳"
                                        Style="{StaticResource IconButton}"
                                        Foreground="{DynamicResource PrimaryBrush}"
                                        Margin="8,0,0,0"
                                        ToolTip="Generar SKU automático"/>
                            </Grid>
                        </StackPanel>

                        <!-- Código de barras -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Código de Barras" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CodigoBarra" Style="{StaticResource FormTextBox}"/>
                                <Button Grid.Column="1"
                                        Content="📷"
                                        Style="{StaticResource IconButton}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Margin="8,0,0,0"
                                        ToolTip="Escanear código de barras"/>
                            </Grid>
                        </StackPanel>

                        <!-- Categoría -->
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Categoría *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CategoriaId"
                                      Height="44" FontSize="14"
                                      Background="{DynamicResource SurfaceBrush}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding Categorias}"
                                      DisplayMemberPath="Nombre"
                                      SelectedValuePath="Id"/>
                        </StackPanel>

                        <!-- Unidad de medida -->
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="Unidad de Medida *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="UnidadMedidaId"
                                      Height="44" FontSize="14"
                                      Background="{DynamicResource SurfaceBrush}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding UnidadesMedida}"
                                      DisplayMemberPath="Nombre"
                                      SelectedValuePath="Id"/>
                        </StackPanel>

                        <!-- Activo -->
                        <StackPanel Grid.Row="4" Grid.Column="2" VerticalAlignment="Bottom">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Height="44" Padding="12,0">
                                <CheckBox x:Name="Activo"
                                          Content="Producto activo"
                                          FontSize="14"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Descripción -->
                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Descripción" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="Descripcion"
                                     Height="80" Padding="12,10" FontSize="14"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{x:Null}">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,10"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush"
                                                        Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- FILA 4 — Precios y Stock -->
            <Border Grid.Row="4"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="24">
                <StackPanel>

                    <TextBlock Text="Precios y Stock"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,24"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Precio Venta -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Precio de Venta *" Style="{StaticResource FieldLabel}"/>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Height="44">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="$" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               VerticalAlignment="Center" Margin="12,0,8,0"/>
                                    <TextBox x:Name="PrecioVentaActual"
                                             Grid.Column="1"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="14" VerticalContentAlignment="Center"
                                             TextAlignment="Right" Padding="0,0,12,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Precio Costo -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Precio de Costo *" Style="{StaticResource FieldLabel}"/>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Height="44">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="$" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0,8,0"/>
                                    <TextBox x:Name="PrecioCostoActual"
                                             Grid.Column="1"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="14" VerticalContentAlignment="Center"
                                             TextAlignment="Right" Padding="0,0,12,0"/>
                                </Grid>
                            </Border>
                            <!-- ✅ CORREGIDO: Mode=OneWay en Run para propiedad calculada -->
                            <TextBlock Foreground="{DynamicResource SuccessBrush}"
                                       FontSize="12" Margin="0,6,0,0">
                                <Run Text="Margen: "/>
                                <Run Text="{Binding MargenCalculado, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Stock Actual -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Stock Actual" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="StockActual"
                                     Style="{StaticResource FormTextBox}"
                                     TextAlignment="Right"/>
                        </StackPanel>

                        <!-- Stock Mínimo -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Stock Mínimo" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="StockMinimo"
                                     Style="{StaticResource FormTextBox}"
                                     TextAlignment="Right"/>
                            <TextBlock Text="Alerta cuando el stock baje de este valor"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- ✅ CORREGIDO: ErrorVisible en lugar de TieneError -->
                    <Border Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}"
                            Background="#1A0A0A"
                            BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="14,10" Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠  "
                                       Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="13" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- FILA 6 — Botones -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 BorderThickness="0"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Margin="0,0,12,0"/>
                    <TextBlock Text="Guardando..."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="Cancelar"
                        Grid.Column="1"
                        Content="Cancelar"
                        Style="{StaticResource SecondaryButton}"
                        Height="44" Padding="28,0" FontSize="14"/>

                <Button x:Name="Guardar"
                        Grid.Column="3"
                        Content="💾  Guardar Producto"
                        Style="{StaticResource PrimaryButton}"
                        Height="44" Padding="28,0" FontSize="14"/>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
