<UserControl x:Class="GestionComercial.UI.Views.Main.Productos.ProductoListadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:EstadoToColorConverter    x:Key="EstadoToColor"/>
        <converters:NullVisibilityConverter   x:Key="NullToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             FILA 0 — Título + botón nuevo producto
        ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Productos"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Administrá el catálogo de productos de la empresa"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Button x:Name="NuevoProducto"
                    Grid.Column="1"
                    Content="+ Nuevo Producto"
                    Style="{StaticResource PrimaryButton}"
                    Height="44" Padding="20,0"
                    FontSize="14"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             FILA 2 — Barra de búsqueda y filtros
        ════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Buscador -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Height="44">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="12,0,8,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TextoBusqueda"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Padding="0,0,12,0"/>
                    </Grid>
                </Border>

                <!-- Filtro Categoría -->
                <ComboBox x:Name="CategoriaSeleccionada"
                          Grid.Column="2"
                          Height="44"
                          Background="{DynamicResource SurfaceBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding Categorias}"
                          DisplayMemberPath="Nombre"
                          SelectedValuePath="Id"/>

                <!-- Filtro Estado -->
                <ComboBox x:Name="FiltroActivo"
                          Grid.Column="4"
                          Height="44"
                          Background="{DynamicResource SurfaceBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          FontSize="14"
                          VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                    <ComboBoxItem Content="Activos"/>
                    <ComboBoxItem Content="Inactivos"/>
                </ComboBox>

                <!-- Botón Buscar -->
                <Button x:Name="Buscar"
                        Grid.Column="6"
                        Content="Buscar"
                        Style="{StaticResource PrimaryButton}"
                        Height="44" Padding="24,0"
                        FontSize="14"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             FILA 4 — Tarjetas resumen
        ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="📦 Total Productos"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TotalProductos}"
                               FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="✅ Activos"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ProductosActivos}"
                               FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="⚠ Stock Bajo"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ProductosStockBajo}"
                               FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource WarningBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="❌ Sin Stock"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ProductosSinStock}"
                               FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             FILA 6 — DataGrid
        ════════════════════════════════════════════════════ -->
        <Border Grid.Row="6"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="ProductoSeleccionado"
                          Grid.Row="0"
                          ItemsSource="{Binding Productos}"
                          Style="{StaticResource DataGridModerno}"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderModerno}"
                          CellStyle="{StaticResource DataGridCellModerno}"
                          RowStyle="{StaticResource DataGridRowModerno}"
                          Background="Transparent"
                          BorderThickness="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Código"    Width="110" Binding="{Binding CodigoBarra}"/>
                        <DataGridTextColumn Header="SKU"       Width="100" Binding="{Binding SKU}"/>
                        <DataGridTextColumn Header="Nombre"    Width="*"   Binding="{Binding Nombre}"/>
                        <DataGridTextColumn Header="Categoría" Width="140" Binding="{Binding Categoria.Nombre}"/>
                        <DataGridTextColumn Header="Unidad"    Width="80"  Binding="{Binding UnidadMedida.Abreviatura}"/>

                        <DataGridTextColumn Header="Precio Venta" Width="130"
                                            Binding="{Binding PrecioVentaActual, Converter={StaticResource DecimalToMoneda}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground"          Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="FontWeight"          Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Precio Costo" Width="130"
                                            Binding="{Binding PrecioCostoActual, Converter={StaticResource DecimalToMoneda}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground"          Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Stock" Width="80" Binding="{Binding StockActual}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight"          Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Estado" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="10,4"
                                            HorizontalAlignment="Center"
                                            Background="{Binding Activo, Converter={StaticResource EstadoToColor}}">
                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Text="{Binding Activo, Converter={StaticResource EstadoToColor}}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Acciones" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏" FontSize="15"
                                                Width="34" Height="34"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                Cursor="Hand" ToolTip="Editar producto"
                                                Command="{Binding DataContext.EditarProductoCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="👁" FontSize="15"
                                                Width="34" Height="34"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Cursor="Hand" ToolTip="Ver detalle"
                                                Command="{Binding DataContext.VerDetalleCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="⏻" FontSize="15"
                                                Width="34" Height="34"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource WarningBrush}"
                                                Cursor="Hand" ToolTip="Activar / Desactivar"
                                                Command="{Binding DataContext.ToggleActivoCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Paginación -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13">
                            <Run Text="Mostrando"/>
                            <Run Text="{Binding ProductosMostrados}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Run Text="de"/>
                            <Run Text="{Binding TotalProductos}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Run Text="productos"/>
                        </TextBlock>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="PaginaAnterior"
                                    Content="← Anterior"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="36" Padding="16,0"
                                    FontSize="13" Margin="0,0,12,0"/>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="8" Padding="12,0">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="13">
                                    <Run Text="Página"/>
                                    <Run Text="{Binding PaginaActual}" FontWeight="SemiBold"/>
                                    <Run Text="de"/>
                                    <Run Text="{Binding TotalPaginas}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </Border>
                            <Button x:Name="PaginaSiguiente"
                                    Content="Siguiente →"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="36" Padding="16,0"
                                    FontSize="13" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="7"
              Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{DynamicResource PrimaryBrush}"
                             BorderThickness="0"
                             Background="{DynamicResource SurfaceBrush}"/>
                <TextBlock Text="Cargando productos..."
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="14" HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
