<Window x:Class="GestionComercial.UI.Views.Main.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters"
        Title="Gestión Comercial - Iniciar Sesión"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Width="1100"
        Height="700"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NullVisibilityConverter   x:Key="NullToVisibility"/>
        <converters:DecimalToMonedaConverter  x:Key="DecimalToMoneda"/>
        <converters:FechaToStringConverter    x:Key="FechaToString"/>
        <converters:EstadoToColorConverter    x:Key="EstadoToColor"/>

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="20" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="30" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="20"
            Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>

            <!-- LADO IZQUIERDO -->
            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A5F" Offset="0"/>
                        <GradientStop Color="#2A4A6F" Offset="0.5"/>
                        <GradientStop Color="#1E3A5F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="60">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                        <!-- LOGO -->
                        <Border Width="180" Height="180" CornerRadius="30" Margin="0,0,0,40"
                                Background="Transparent">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
                            </Border.Effect>
                            <Image Source="/Views/Recursos/Imagenes/logo.png"
                                   Width="180" Height="180" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <TextBlock Text="Gestión Comercial" FontSize="36" FontWeight="Bold"
                                   Foreground="#E0F2FE" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Sistema integral de administración empresarial"
                                   FontSize="16" Foreground="#7DD3FC" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                        <TextBlock Text="© 2025 Gestión Comercial" FontSize="12"
                                   Foreground="#7DD3FC" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- LADO DERECHO -->
            <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="0,20,20,0">
                <Grid Margin="60,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Botón cerrar -->
                    <Button Content="✕" Width="36" Height="36" FontSize="18"
                            Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,20,20,0" Cursor="Hand" Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- ═══════════════════════════════════════════════════
                         PANEL LOGIN
                    ════════════════════════════════════════════════════ -->
                    <StackPanel Grid.Row="1" x:Name="PanelLogin" VerticalAlignment="Center"
                                Opacity="0" Loaded="Grid_Loaded">
                        <StackPanel.RenderTransform><TranslateTransform/></StackPanel.RenderTransform>

                        <TextBlock Text="Bienvenido" FontSize="32" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Ingresá tus credenciales para continuar"
                                   FontSize="15" Margin="0,0,0,48"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <!-- Usuario -->
                        <TextBlock Text="Usuario" FontSize="14" FontWeight="Medium"
                                   Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox x:Name="Usuario" Height="52" Padding="18,0" FontSize="15"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="1" VerticalContentAlignment="Center"
                                 Margin="0,0,0,24" TextChanged="UsuarioBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Contraseña -->
                        <TextBlock Text="Contraseña" FontSize="14" FontWeight="Medium"
                                   Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Margin="0,0,0,12" Height="52">
                            <PasswordBox x:Name="PasswordBox" Padding="18,0" FontSize="15"
                                         Background="{DynamicResource SurfaceBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="1" VerticalContentAlignment="Center"
                                         PasswordChanged="PasswordBox_PasswordChanged">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="PasswordBox">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>
                            <TextBox x:Name="PasswordVisible" Padding="18,0" FontSize="15"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="1" VerticalContentAlignment="Center"
                                     Visibility="Collapsed" IsReadOnly="True">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{DynamicResource PrimaryBrush}"
                                                            BorderThickness="2" CornerRadius="12">
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button x:Name="TogglePassword" Width="36" Height="36"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,10,0" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Content="○" FontSize="16" Click="TogglePassword_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Error -->
                        <Border Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}"
                                Background="#1A0A0A" BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,24">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="16" Foreground="{DynamicResource ErrorBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Botón Login -->
                        <Button x:Name="LoginCommand" Content="Iniciar Sesión" Height="52"
                                Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="16" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,8,0,0"
                                     Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0"
                                     Background="Transparent"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Link olvidé contraseña -->
                        <TextBlock x:Name="LinkOlvideContrasena"
                                   Text="¿Olvidaste tu contraseña?" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,24,0,0" Cursor="Hand"
                                   MouseLeftButtonUp="OlvideContrasena_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════════
                         PANEL RECUPERACIÓN — PASO 1: Email
                    ════════════════════════════════════════════════════ -->
                    <StackPanel Grid.Row="1" x:Name="PanelRecupEmail"
                                VerticalAlignment="Center" Visibility="Collapsed" Opacity="0">
                        <StackPanel.RenderTransform><TranslateTransform/></StackPanel.RenderTransform>

                        <Button Content="← Volver" HorizontalAlignment="Left" Margin="0,0,0,32"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                Click="VolverAlLogin_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Text="Recuperar contraseña" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Ingresá tu email para encontrar tu cuenta"
                                   FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,40"/>

                        <TextBlock Text="Email" FontSize="14" FontWeight="Medium"
                                   Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox x:Name="RecupEmail" Height="52" Padding="18,0" FontSize="15"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="1" VerticalContentAlignment="Center" Margin="0,0,0,24">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Border x:Name="ErrorRecupEmail" Visibility="Collapsed"
                                Background="#1A0A0A" BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                            <TextBlock x:Name="ErrorRecupEmailText" Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="14" TextWrapping="Wrap"/>
                        </Border>

                        <Button Content="Continuar" Height="52" Click="RecupEmail_Continuar"
                                Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="16" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════════
                         PANEL RECUPERACIÓN — PASO 2: Pregunta secreta
                    ════════════════════════════════════════════════════ -->
                    <StackPanel Grid.Row="1" x:Name="PanelRecupPregunta"
                                VerticalAlignment="Center" Visibility="Collapsed" Opacity="0">
                        <StackPanel.RenderTransform><TranslateTransform/></StackPanel.RenderTransform>

                        <Button Content="← Volver" HorizontalAlignment="Left" Margin="0,0,0,32"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                Click="VolverAEmail_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Text="Pregunta de seguridad" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Respondé tu pregunta secreta para continuar"
                                   FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,32"/>

                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
                                Padding="18,14" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="Tu pregunta:" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TextPregunta" FontSize="14" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Tu respuesta" FontSize="14" FontWeight="Medium"
                                   Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <PasswordBox x:Name="RecupRespuesta" Height="52" Padding="18,0" FontSize="15"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="1" VerticalContentAlignment="Center" Margin="0,0,0,24">
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="PasswordBox">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>

                        <Border x:Name="ErrorRecupPregunta" Visibility="Collapsed"
                                Background="#1A0A0A" BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                            <TextBlock x:Name="ErrorRecupPreguntaText" Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="14" TextWrapping="Wrap"/>
                        </Border>

                        <Button Content="Verificar respuesta" Height="52" Click="RecupPregunta_Verificar"
                                Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="16" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- ═══════════════════════════════════════════════════
                         PANEL RECUPERACIÓN — PASO 3: Nueva contraseña
                    ════════════════════════════════════════════════════ -->
                    <StackPanel Grid.Row="1" x:Name="PanelRecupNuevaContrasena"
                                VerticalAlignment="Center" Visibility="Collapsed" Opacity="0">
                        <StackPanel.RenderTransform><TranslateTransform/></StackPanel.RenderTransform>

                        <TextBlock Text="Nueva contraseña" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Elegí una contraseña segura de al menos 8 caracteres"
                                   FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,40"/>

                        <TextBlock Text="Nueva contraseña" FontSize="14" FontWeight="Medium"
                                   Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <PasswordBox x:Name="NuevaContrasena" Height="52" Padding="18,0" FontSize="15"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="1" VerticalContentAlignment="Center" Margin="0,0,0,20">
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="PasswordBox">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>

                        <TextBlock Text="Confirmá la contraseña" FontSize="14" FontWeight="Medium"
                                   Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <PasswordBox x:Name="ConfirmarContrasena" Height="52" Padding="18,0" FontSize="15"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="1" VerticalContentAlignment="Center" Margin="0,0,0,24">
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="PasswordBox">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>

                        <Border x:Name="ErrorNuevaContrasena" Visibility="Collapsed"
                                Background="#1A0A0A" BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                            <TextBlock x:Name="ErrorNuevaContrasenaText" Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="14" TextWrapping="Wrap"/>
                        </Border>

                        <Button Content="Cambiar contraseña" Height="52" Click="CambiarContrasena_Click"
                                Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" FontSize="16" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
