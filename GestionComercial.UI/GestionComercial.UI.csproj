<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
	</PropertyGroup>
	<ItemGroup>
	  <Compile Remove="using GestionComercial.UI.using GestionComercial.UI.Viewmodels.s\**" />
	  <EmbeddedResource Remove="using GestionComercial.UI.using GestionComercial.UI.Viewmodels.s\**" />
	  <None Remove="using GestionComercial.UI.using GestionComercial.UI.Viewmodels.s\**" />
	  <Page Remove="using GestionComercial.UI.using GestionComercial.UI.Viewmodels.s\**" />
	</ItemGroup>
	<ItemGroup>
	  <None Remove="Views\Recursos\Imagenes\Fondo.png" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\GestionComercial.Aplicacion\GestionComercial.Aplicacion.csproj" />
	</ItemGroup>
	<ItemGroup>
		<Folder Include="Views\Comandos\" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Caliburn.Micro" Version="4.0.212" />
		<PackageReference Include="ClosedXML" Version="0.105.0" />
		<PackageReference Include="LiveChartsCore.SkiaSharpView.WPF" Version="2.0.0-rc6.1" />
	</ItemGroup>
	<ItemGroup>
	  <Resource Include="Views\Recursos\Imagenes\Fondo.png">
	    <CopyToOutputDirectory>Never</CopyToOutputDirectory>
	  </Resource>
	</ItemGroup>
	<ItemGroup>
	  <Page Update="Views\Recursos\Estilos\ThemeDark.xaml">
	    <CopyToOutputDirectory>Never</CopyToOutputDirectory>
	  </Page>
	  <Page Update="Views\Recursos\Estilos\ThemeLight.xaml">
	    <CopyToOutputDirectory>Never</CopyToOutputDirectory>
	  </Page>
	</ItemGroup>
</Project>