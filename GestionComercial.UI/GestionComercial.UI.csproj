<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net8.0-windows</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<UseWPF>true</UseWPF>
		<OutputType>WinExe</OutputType>
		<!-- NU1701: OpenTK y SkiaSharp son dependencias transitivas de LiveCharts, compatibles en runtime -->
		<!-- CS8618: suprimido en ViewModels porque se inicializan por binding o constructor -->
		<NoWarn>$(NoWarn);NU1701;CS8618</NoWarn>
	</PropertyGroup>
	<ItemGroup>
	  <None Remove="Views\Recursos\Imagenes\logo.png" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\GestionComercial.Aplicacion\GestionComercial.Aplicacion.csproj" />
		<ProjectReference Include="..\GestionComercial.Dominio\GestionComercial.Dominio.csproj" />
		<ProjectReference Include="..\GestionComercial.Infraestructura\GestionComercial.Infraestructura.csproj" />
		<ProjectReference Include="..\GestionComercial.Persistencia\GestionComercial.Persistencia.csproj" />
	</ItemGroup>
	<ItemGroup>
		<None Update="appsettings.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Caliburn.Micro" Version="4.0.212" />
		<PackageReference Include="ClosedXML" Version="0.102.3" />
		<PackageReference Include="LiveChartsCore.SkiaSharpView.WPF" Version="2.0.0-rc5.4" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.0" />
		<PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
		<PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.0" />
		<PackageReference Include="Microsoft.Extensions.Configuration.FileExtensions" Version="8.0.0" />
		<PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
	</ItemGroup>

	<ItemGroup>
	  <Resource Include="Views\Recursos\Imagenes\logo.png" />
	</ItemGroup>
</Project>