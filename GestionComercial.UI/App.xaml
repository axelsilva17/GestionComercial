<Application x:Class="GestionComercial.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GestionComercial.UI"
             xmlns:converters="clr-namespace:GestionComercial.UI.Views.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Converters globales -->
            <converters:DecimalToMonedaConverter x:Key="DecimalToMoneda"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:BoolToColorConverter x:Key="BoolToColor"/>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacity"/>
            <converters:InverseBoolConverter x:Key="InverseBool"/>
            <converters:NullVisibilityConverter x:Key="NullVisibility"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibility"/>
            <converters:EstadoToColorConverter x:Key="EstadoToColor"/>
            <converters:FechaToStringConverter x:Key="FechaToString"/>
            <converters:DiferenciaToColorConverter x:Key="DiferenciaToColor"/>
            <converters:EnumToIntConverter x:Key="EnumToInt"/>
            <converters:ProgressToWidthConverter x:Key="ProgressToWidth"/>
            <converters:TabConverters x:Key="TabConverters"/>
            
            <!-- Estilos globales de cursor -->
            <Style TargetType="Button">
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style TargetType="ListBoxItem">
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            
            <ResourceDictionary.MergedDictionaries>
               

                <!-- Tema dinamico -->
                <ResourceDictionary Source="/Views/Recursos/Estilos/ThemeLight.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Diccionarios/Colors.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Diccionarios/Elevaciones.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Diccionarios/Espaciado.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Diccionarios/Fuentes.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Diccionarios/Iconos.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Estilos/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Estilos/CardStyles.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Estilos/DataGridStyles.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Estilos/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Estilos/ComboBoxStyles.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Estilos/FilterStyles.xaml"/>
                <ResourceDictionary Source="/Views/Recursos/Estilos/Animations.xaml"/>
                
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>